---
---

<div class="qt-bg-fx" aria-hidden="true" transition:persist>
  <div class="qt-bg-mesh"></div>
  <svg
    class="qt-bg-noise"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="none"
  >
    <filter id="qt-noise-filter">
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.9"
        numOctaves="2"
        stitchTiles="stitch"
      />
      <feColorMatrix type="saturate" values="0" />
    </filter>
    <rect width="100%" height="100%" filter="url(#qt-noise-filter)" />
  </svg>
</div>

<style>
  .qt-bg-fx {
    position: fixed;
    inset: 0;
    z-index: -2;
    pointer-events: none;
    overflow: hidden;
  }

  .qt-bg-mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        50vw 40vw at 12% 8%,
        color-mix(in srgb, var(--accent) 8%, transparent),
        transparent 70%
      ),
      radial-gradient(
        60vw 50vw at 88% 92%,
        color-mix(in srgb, var(--accent) 5%, transparent),
        transparent 75%
      ),
      radial-gradient(
        40vw 30vw at 8% 95%,
        color-mix(in srgb, var(--subtle) 7%, transparent),
        transparent 70%
      );
  }

  .qt-bg-noise {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.04;
    mix-blend-mode: multiply;
  }
</style>
