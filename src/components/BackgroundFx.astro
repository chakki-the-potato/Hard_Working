---
---

<div class="qt-bg-fx" aria-hidden="true" transition:persist>
  <div class="qt-bg-mesh"></div>
  <svg
    class="qt-bg-noise"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="none"
  >
    <filter id="qt-noise-filter">
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.9"
        numOctaves="2"
        stitchTiles="stitch"
      />
      <feColorMatrix type="saturate" values="0" />
    </filter>
    <rect width="100%" height="100%" filter="url(#qt-noise-filter)" />
  </svg>
  <div class="qt-bg-aurora">
    <div class="qt-aurora-layer qt-aurora-1"></div>
    <div class="qt-aurora-layer qt-aurora-2"></div>
  </div>
</div>

<style>
  .qt-bg-fx {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
  }

  .qt-bg-mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        50vw 40vw at 12% 8%,
        color-mix(in srgb, var(--accent) 8%, transparent),
        transparent 70%
      ),
      radial-gradient(
        60vw 50vw at 88% 92%,
        color-mix(in srgb, var(--accent) 5%, transparent),
        transparent 75%
      ),
      radial-gradient(
        40vw 30vw at 8% 95%,
        color-mix(in srgb, var(--subtle) 7%, transparent),
        transparent 70%
      );
  }

  .qt-bg-noise {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.04;
    mix-blend-mode: multiply;
  }

  .qt-bg-aurora {
    position: absolute;
    inset: 0;
    overflow: hidden;
    filter: blur(60px);
  }

  .qt-aurora-layer {
    position: absolute;
    border-radius: 50%;
    will-change: transform;
  }

  .qt-aurora-1 {
    top: -10%;
    left: 5%;
    width: 70%;
    height: 60%;
    background: radial-gradient(
      ellipse at center,
      color-mix(in srgb, var(--accent) 55%, transparent),
      transparent 65%
    );
    opacity: 0.45;
    animation: qt-aurora-drift-1 90s ease-in-out infinite alternate;
  }

  .qt-aurora-2 {
    bottom: -15%;
    right: 0%;
    width: 65%;
    height: 55%;
    background: radial-gradient(
      ellipse at center,
      color-mix(in srgb, #8B5CF6 50%, transparent),
      transparent 65%
    );
    opacity: 0.35;
    animation: qt-aurora-drift-2 120s ease-in-out infinite alternate;
  }

  @keyframes qt-aurora-drift-1 {
    0%   { transform: translate(-4%, -2%) rotate(-4deg); }
    50%  { transform: translate(3%, 4%) rotate(2deg);  }
    100% { transform: translate(5%, -3%) rotate(6deg);  }
  }

  @keyframes qt-aurora-drift-2 {
    0%   { transform: translate(3%, 2%)  rotate(3deg);  }
    50%  { transform: translate(-4%, -3%) rotate(-2deg); }
    100% { transform: translate(-2%, 4%) rotate(-5deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .qt-aurora-layer {
      animation: none;
    }
  }
</style>
