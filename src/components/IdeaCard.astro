---
import { render, type CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'ideas'>;
}

const { entry } = Astro.props;
const { title, pubDate, tags } = entry.data;
const { Content } = await render(entry);
---

<article class="idea-card">
  <header class="idea-card-meta">
    <div class="idea-card-tags">
      {tags.map((tag) => (
        <span class="tag-badge">{tag}</span>
      ))}
    </div>
    <time datetime={pubDate.toISOString()} class="idea-card-date">
      {pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
  </header>

  <h2 class="idea-card-title">{title}</h2>

  <div class="idea-card-body prose">
    <Content />
  </div>
</article>

<style>
  .idea-card {
    padding: 32px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .idea-card:last-child {
    border-bottom: none;
  }

  .idea-card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }

  .idea-card-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .tag-badge {
    display: inline-flex;
    align-items: center;
    font-size: 13px;
    font-weight: 600;
    background-color: var(--color-bg-badge);
    color: var(--color-muted);
    border-radius: 8px;
    padding: 2px 10px;
    white-space: nowrap;
  }

  .idea-card-date {
    font-size: 13px;
    color: var(--color-subtle);
  }

  .idea-card-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--color-heading);
    line-height: 1.4;
    margin: 0 0 16px 0;
    letter-spacing: -0.01em;
  }

  .idea-card-body :global(:first-child) {
    margin-top: 0 !important;
  }

  .idea-card-body :global(h2) {
    font-size: 16px;
    font-weight: 700;
    color: var(--color-heading);
    margin: 24px 0 8px 0;
  }

  .idea-card-body :global(p) {
    font-size: 15px;
    color: var(--color-muted);
    line-height: 1.7;
    margin: 0 0 12px 0;
  }

  .idea-card-body :global(ul) {
    margin: 0 0 12px 0;
    padding-left: 20px;
  }

  .idea-card-body :global(li) {
    font-size: 15px;
    color: var(--color-muted);
    line-height: 1.7;
    margin-bottom: 4px;
  }

  .idea-card-body :global(a) {
    color: var(--color-heading);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .idea-card-body :global(a:hover) {
    opacity: 0.7;
  }

  @media (max-width: 600px) {
    .idea-card-title {
      font-size: 18px;
    }
  }
</style>
