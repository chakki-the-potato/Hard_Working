---
import { categoryLabel, type Category } from '../lib/categories';

interface Props {
  id: string;
  title: string;
  description: string;
  pubDate: Date;
  category: Category;
  tags: string[];
  num?: number;
  showMono?: boolean;
}

const { id, title, description, pubDate, category, tags, num, showMono = true } = Astro.props;
const base = import.meta.env.BASE_URL;

const cat = categoryLabel(category);
const sub = tags[0] ?? '';
const dateLabel = pubDate
  .toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' })
  .replace(/\.\s*/g, '.')
  .replace(/\.$/, '');

const numLabel = num != null ? String(num).padStart(3, '0') : null;
---

<a href={`${base}posts/${id}/`} class="qt-feat-row">
  <aside class="qt-feat-meta">
    <div class="qt-feat-cat">[{cat.toUpperCase()}]</div>
    {sub && <div class="qt-feat-sub">{sub}</div>}
    <div class="qt-feat-date">{dateLabel}</div>
  </aside>
  <div class="qt-feat-body">
    <h2 class="qt-feat-title">{title}</h2>
    <p class="qt-feat-desc">{description}</p>
    {showMono && (
      <div class="qt-feat-foot">
        {numLabel && <span>№ {numLabel}</span>}
        {numLabel && <span>·</span>}
        <span>READ MORE →</span>
      </div>
    )}
  </div>
</a>

<style>
  .qt-feat-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 36px;
    padding: 26px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .qt-feat-row:hover .qt-feat-title {
    color: var(--accent);
  }

  .qt-feat-row:hover .qt-feat-foot {
    color: var(--accent);
    transform: translateX(4px);
  }

  .qt-feat-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
    line-height: 1.85;
  }

  .qt-feat-cat {
    color: var(--accent);
    font-weight: 600;
  }

  .qt-feat-sub {
    color: var(--muted);
  }

  .qt-feat-date {
    color: var(--subtle);
    margin-top: 10px;
  }

  .qt-feat-body {
    min-width: 0;
  }

  .qt-feat-title {
    font-size: 26px;
    font-weight: 700;
    line-height: 1.28;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 0 0 10px;
    transition: color 0.15s;
  }

  .qt-feat-desc {
    font-size: 14.5px;
    line-height: 1.7;
    color: var(--muted);
    margin: 0;
    max-width: 640px;
    font-weight: 500;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .qt-feat-foot {
    margin-top: 14px;
    display: flex;
    gap: 14px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--subtle);
    letter-spacing: 0.06em;
    transition: color 0.15s, transform 0.15s;
  }

  @media (max-width: 720px) {
    .qt-feat-row {
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 22px 0;
    }
    .qt-feat-meta {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      line-height: 1.4;
    }
    .qt-feat-date {
      margin-top: 0;
    }
    .qt-feat-title {
      font-size: 20px;
    }
  }
</style>
