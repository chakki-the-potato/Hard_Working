---
import { TAG_COLORS, DEFAULT_TAG_COLOR } from '../consts';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  id: string;
}

const { title, description, pubDate, tags, id } = Astro.props;
const base = import.meta.env.BASE_URL;
const accentColor = TAG_COLORS[tags[0]] ?? DEFAULT_TAG_COLOR;
---

<a
  href={`${base}posts/${id}/`}
  class="block rounded-xl p-5 transition-opacity hover:opacity-70 active:opacity-90 overflow-hidden"
  style={`background-color: var(--bg-secondary); border-top: 3px solid ${accentColor};`}
>
  <div class="flex flex-wrap gap-1.5 mb-2">
    {tags.map((tag) => (
      <span
        class="text-xs px-2 py-0.5 rounded-full font-medium"
        style={`background-color: ${TAG_COLORS[tag] ?? DEFAULT_TAG_COLOR}20; color: var(--text-primary); border: 1px solid ${TAG_COLORS[tag] ?? DEFAULT_TAG_COLOR}90;`}
      >
        {tag}
      </span>
    ))}
  </div>
  <h2 class="text-base font-bold mb-1.5 line-clamp-2" style="color: var(--text-primary);">
    {title}
  </h2>
  <p class="text-sm line-clamp-3 mb-3" style="color: var(--text-secondary);">
    {description}
  </p>
  <time datetime={pubDate.toISOString()} class="text-xs" style="color: var(--text-secondary);">
    {pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
  </time>
</a>
