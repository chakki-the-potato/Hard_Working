---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  id: string;
  heroImage?: string;
}

const { title, description, pubDate, tags, id, heroImage } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a href={`${base}posts/${id}/`} class="post-card block rounded-xl overflow-hidden bg-white" style="border: 1px solid var(--border); box-shadow: var(--card-shadow);">
  <div class="img-wrap" style="height: 160px; overflow: hidden;">
    {heroImage
      ? <img src={heroImage} alt={title} style="width: 100%; height: 100%; object-fit: cover;" loading="lazy" />
      : <div class="placeholder" style="width: 100%; height: 100%; background-color: #f0f0f0; display: flex; align-items: center; justify-content: center;">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#d0d0d0" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
        </div>
    }
  </div>
  <div class="p-4">
    <div class="flex flex-wrap gap-1.5 mb-3">
      {tags.map((tag) => (
        <span class="text-xs px-2.5 py-1 rounded-full font-medium" style="background-color: #f0f0f0; color: var(--text-secondary);">
          {tag}
        </span>
      ))}
    </div>
    <h2 class="text-base font-bold mb-2 line-clamp-2" style="color: var(--text-primary); line-height: 1.5;">
      {title}
    </h2>
    <p class="text-sm line-clamp-3 mb-4" style="color: var(--text-secondary); line-height: 1.6;">
      {description}
    </p>
    <time datetime={pubDate.toISOString()} class="text-xs" style="color: #afafaf;">
      {pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
  </div>
</a>

<style>
  .post-card {
    transition: box-shadow 0.2s ease;
  }
  .post-card:hover {
    box-shadow: var(--card-shadow-hover);
  }
</style>
