---
import { getCollection } from 'astro:content';

interface Props {
  activeTag?: string;
}

const { activeTag } = Astro.props;
const base = import.meta.env.BASE_URL;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const tagCounts = new Map<string, number>();
allPosts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});
const sortedTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<div class="tagnav-wrap">
  <nav class="tagnav scrollbar-hide" aria-label="태그 필터">
    <a
      href={base}
      class={`tagnav-chip ${!activeTag ? 'tagnav-active' : 'tagnav-inactive'}`}
    >
      전체
    </a>
    {sortedTags.map(([tag, count]) => (
      <a
        href={`${base}tags/${tag}/`}
        class={`tagnav-chip ${activeTag === tag ? 'tagnav-active' : 'tagnav-inactive'}`}
        aria-current={activeTag === tag ? 'page' : undefined}
      >
        {tag}
      </a>
    ))}
  </nav>
  <div class="tagnav-fade" id="tagnav-fade"></div>
</div>

<script>
  const nav = document.querySelector('.tagnav') as HTMLElement;
  const fade = document.getElementById('tagnav-fade');

  function updateFade() {
    if (!nav || !fade) return;
    const atEnd = nav.scrollLeft + nav.clientWidth >= nav.scrollWidth - 4;
    fade.style.opacity = atEnd ? '0' : '1';
  }

  if (nav) {
    nav.addEventListener('scroll', updateFade, { passive: true });
    updateFade();
  }
</script>

<style>
  .tagnav-wrap {
    position: relative;
    margin-bottom: 2rem;
  }

  .tagnav {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    padding-bottom: 2px;
  }

  .tagnav-fade {
    position: absolute;
    top: 0;
    right: 0;
    width: 60px;
    height: calc(100% - 2px);
    background: linear-gradient(to right, transparent, #ffffff);
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .tagnav-chip {
    flex-shrink: 0;
    padding: 6px 14px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    white-space: nowrap;
    transition: opacity 0.15s;
    text-decoration: none;
    line-height: 1.4;
  }

  .tagnav-chip:hover {
    opacity: 0.7;
  }

  .tagnav-active {
    background-color: var(--color-heading);
    color: #ffffff;
  }

  .tagnav-inactive {
    background-color: var(--color-bg-badge);
    color: var(--color-muted);
  }
</style>
