---
import { getCollection } from 'astro:content';
import {
  ALWAYS_VISIBLE_TAGS_PER_CATEGORY,
  categoryLabel,
  type Category,
} from '../lib/categories';
import { extractProjectSlug, projectLabel } from '../lib/projects';

interface Props {
  activeCategory?: Category;
  activeTag?: string;
  activeProject?: string;
  showCount?: boolean;
}

const { activeCategory, activeTag, activeProject, showCount = false } = Astro.props;
const base = import.meta.env.BASE_URL;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const scopedPosts = activeCategory
  ? allPosts.filter((p) => p.data.category === activeCategory)
  : allPosts;

// Split scoped posts: project posts get folded into a single project chip;
// non-project posts feed the regular tag chips so chip area stays compact.
const projectCounts = new Map<string, number>();
const nonProjectPosts: typeof scopedPosts = [];
for (const post of scopedPosts) {
  const slug = extractProjectSlug(post);
  if (slug) {
    projectCounts.set(slug, (projectCounts.get(slug) ?? 0) + 1);
  } else {
    nonProjectPosts.push(post);
  }
}

const projectMetas = await getCollection('projects');
const metaBySlug = new Map(projectMetas.map((m) => [m.id, m]));

const projectChips = [...projectCounts.entries()]
  .map(([slug, count]) => ({
    slug,
    label: metaBySlug.get(slug)?.data.title ?? projectLabel(slug),
    count,
  }))
  .sort((a, b) => b.count - a.count || a.label.localeCompare(b.label));

const tagCounts = new Map<string, number>();
nonProjectPosts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});

// Force-show whitelisted sub-tags (e.g. Tools under programming) even with 0 posts.
if (activeCategory) {
  const alwaysTags = ALWAYS_VISIBLE_TAGS_PER_CATEGORY[activeCategory] ?? [];
  for (const tag of alwaysTags) {
    if (!tagCounts.has(tag)) tagCounts.set(tag, 0);
  }
}

const sortedTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);

const allHref = activeCategory ? `${base}posts/category/${activeCategory}/` : base;
const allLabel = activeCategory ? categoryLabel(activeCategory) : '전체';
const allActive = !activeTag && !activeProject;
const allCount = scopedPosts.length;
---

<div class="qt-tag-chips" role="navigation" aria-label="태그 필터">
  {activeCategory ? (
    <a href={base} class="qt-chip">전체</a>
  ) : (
    <a
      href={allHref}
      class:list={['qt-chip', { 'is-active': allActive }]}
    >
      {allLabel}{showCount && <span class="qt-chip-count">{allCount}</span>}
    </a>
  )}
  {projectChips.map((p) => (
    <a
      href={`${base}projects/${p.slug}/`}
      class:list={['qt-chip', 'qt-chip-project', { 'is-active': activeProject === p.slug }]}
      aria-current={activeProject === p.slug ? 'page' : undefined}
    >
      <span class="qt-chip-arrow" aria-hidden="true">▸</span>{' '}{p.label}<span class="qt-chip-count">{p.count}</span>
    </a>
  ))}
  {sortedTags.map(([tag, count]) => (
    <a
      href={`${base}tags/${tag}/`}
      class:list={['qt-chip', { 'is-active': activeTag === tag }]}
      aria-current={activeTag === tag ? 'page' : undefined}
    >
      {tag}{showCount && <span class="qt-chip-count">{count}</span>}
    </a>
  ))}
</div>

<style>
  .qt-tag-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .qt-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 11px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    border-radius: 4px;
    color: var(--muted);
    background: var(--bg-alt);
    border: 1px solid var(--border);
    text-decoration: none;
    transition: opacity 0.15s;
    white-space: nowrap;
  }

  .qt-chip:hover {
    opacity: 0.78;
  }

  .qt-chip.is-active {
    color: var(--bg-elev);
    background: var(--ink);
    border-color: var(--ink);
    font-weight: 600;
  }

  .qt-chip-count {
    font-size: 10.5px;
    opacity: 0.7;
  }

  .qt-chip-arrow {
    font-size: 11px;
    color: var(--accent);
    margin-right: 1px;
  }

  .qt-chip-project.is-active .qt-chip-arrow {
    color: var(--bg-elev);
  }
</style>
