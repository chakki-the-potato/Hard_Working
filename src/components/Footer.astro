      <div class="qt-footer-cols">
        <div class="qt-footer-col">
          <span class="qt-footer-label">SECTIONS</span>
          <a href={`${base}posts/category/programming/`}>Programming</a>
          <a href={`${base}posts/category/thinking/`}>Thinking</a>
          <a href={`${base}posts/category/design/`}>Design</a>
          <a href={`${base}posts/category/works/`}>Works</a>
          <a href={`${base}ideas/`}>Ideas</a>
        </div>
        <div class="qt-footer-col">
          <span class="qt-footer-label">META</span>
          <a href={`${base}about/`}>About</a>
          <a href={`${base}rss.xml`}>RSS</a>
          <a href={`${base}search/`}>Search</a>
        </div>
      </div>
    </div>

    <div class="qt-footer-bottom">
      <span>© {currentYear} HARD_WORKING. ALL NOTES, NO NOISE.</span>
      <span>BUILT WITH ASTRO ─ DEPLOYED ON GITHUB PAGES</span>
    </div>
  </div>
</footer>

<style>
  .qt-footer {
    border-top: 1px solid var(--border);
    margin-top: 64px;
    background: var(--bg);
  }

  .qt-footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 36px 36px 28px;
  }

  .qt-footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 32px;
    flex-wrap: wrap;
  }

  .qt-footer-brand {
    display: flex;
    align-items: flex-start;
    gap: 6px;
  }

  .qt-footer-logo-link {
    display: inline-flex;
    flex-shrink: 0;
  }

  .qt-footer-logo-img {
    display: block;
  }

  .qt-footer-brand-text {
    display: flex;
    flex-direction: column;
  }

  .qt-footer-name {
    color: var(--ink);
    text-decoration: none;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .qt-footer-tagline {
    font-size: 12.5px;
    color: var(--muted);
    margin: 0;
    max-width: 380px;
    line-height: 1.65;
  }

  .qt-footer-social {
    display: flex;
    gap: 14px;
    margin-top: 12px;
  }

  .qt-footer-social a {
    display: inline-flex;
    color: var(--muted);
    transition: color 0.15s;
  }

  .qt-footer-social a:hover {
    color: var(--ink);
  }

  .qt-footer-social svg {
    width: 18px;
    height: 18px;
    display: block;
  }

  .qt-footer-cols {
    display: flex;
    gap: 48px;
    font-size: 12.5px;
  }

  .qt-footer-col {
    display: flex;
    flex-direction: column;
  }

  .qt-footer-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--subtle);
    letter-spacing: 0.1em;
    margin-bottom: 8px;
  }

  .qt-footer-col a {
    color: var(--muted);
    text-decoration: none;
    padding: 3px 0;
    transition: color 0.15s;
  }

  .qt-footer-col a:hover {
    color: var(--ink);
  }

  .qt-footer-bottom {
    margin-top: 32px;
    padding-top: 16px;
    border-top: 1px solid var(--border-hair);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--subtle);
    letter-spacing: 0.06em;
    flex-wrap: wrap;
    gap: 12px;
  }

  @media (max-width: 720px) {
    .qt-footer-inner {
      padding: 32px 20px 24px;
    }
    .qt-footer-cols {
      gap: 32px;
    }
  }
</style>
