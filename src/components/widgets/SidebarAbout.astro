---
const base = import.meta.env.BASE_URL;
---

<section class="qt-w-about">
  <span class="qt-w-mono">// ABOUT</span>
  <p class="qt-w-about-bio">
    <strong>Hard_Working</strong> · 개발 공부 기록.<br />
    Programming · Thinking · Design 을 매일 한 줄씩.
  </p>
  <ul class="qt-w-about-links">
    <li>
      <a href={`${base}ideas/`}>SCRATCHPAD <span aria-hidden="true">→</span></a>
    </li>
    <li>
      <a href={`${base}rss.xml`}>RSS FEED <span aria-hidden="true">→</span></a>
    </li>
  </ul>
</section>

<style>
  .qt-w-about {
    padding: 0;
  }

  .qt-w-mono {
    display: block;
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: 0.14em;
    margin-bottom: 10px;
  }

  .qt-w-about-bio {
    margin: 0 0 12px;
    font-size: 13px;
    line-height: 1.65;
    color: var(--muted);
  }

  .qt-w-about-bio strong {
    color: var(--ink);
    font-weight: 700;
  }

  .qt-w-about-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .qt-w-about-links a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 8px;
    border-radius: 5px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-decoration: none;
    transition: background-color 0.12s, color 0.12s;
  }

  .qt-w-about-links a:hover {
    background: var(--bg-alt);
    color: var(--ink);
  }
</style>
