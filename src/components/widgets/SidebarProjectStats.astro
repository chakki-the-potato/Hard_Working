---
import type { ProjectSummary } from '../../lib/projects';

interface Props {
  projects: ProjectSummary[];
  limit?: number;
}

const { projects, limit = 6 } = Astro.props;
const base = import.meta.env.BASE_URL;

const visible = projects.filter((p) => p.count > 0).slice(0, limit);
const hasMore = projects.filter((p) => p.count > 0).length > visible.length;
const max = Math.max(1, ...visible.map((p) => p.count));
const rows = visible.map((p) => ({
  slug: p.slug,
  label: p.label,
  count: p.count,
  pct: Math.round((p.count / max) * 100),
}));
---

{rows.length > 0 && (
  <section class="qt-w-stats">
    <div class="qt-w-head">
      <span class="qt-w-mono">// PROJECT</span>
      <a class="qt-w-more" href={`${base}projects/`}>ALL →</a>
    </div>
    <ul class="qt-w-stats-list">
      {rows.map((row) => (
        <li>
          <a class="qt-w-stats-row" href={`${base}projects/${row.slug}/`}>
            <span class="qt-w-stats-name">{row.label}</span>
            <span class="qt-w-stats-count">{String(row.count).padStart(2, '0')}</span>
            <span class="qt-w-stats-track" aria-hidden="true">
              <span class="qt-w-stats-bar" style={`width: ${row.pct}%`}></span>
            </span>
          </a>
        </li>
      ))}
    </ul>
    {hasMore && (
      <a class="qt-w-foot" href={`${base}projects/`}>전체 보기</a>
    )}
  </section>
)}

<style>
  .qt-w-stats {
    padding: 0;
  }

  .qt-w-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .qt-w-mono {
    display: block;
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: 0.14em;
  }

  .qt-w-more {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--subtle);
    letter-spacing: 0.08em;
    text-decoration: none;
    transition: color 0.12s;
  }

  .qt-w-more:hover {
    color: var(--ink);
  }

  .qt-w-stats-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .qt-w-stats-row {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      'name count'
      'track track';
    column-gap: 8px;
    row-gap: 5px;
    text-decoration: none;
    color: inherit;
    padding: 2px 0;
    transition: opacity 0.12s;
  }

  .qt-w-stats-row:hover {
    opacity: 0.7;
  }

  .qt-w-stats-name {
    grid-area: name;
    font-size: 12.5px;
    color: var(--ink);
    font-weight: 500;
  }

  .qt-w-stats-count {
    grid-area: count;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--subtle);
    letter-spacing: 0.06em;
  }

  .qt-w-stats-track {
    grid-area: track;
    height: 3px;
    background: var(--bg-alt);
    border-radius: 2px;
    overflow: hidden;
  }

  .qt-w-stats-bar {
    display: block;
    height: 100%;
    background: var(--accent);
    border-radius: 2px;
  }

  .qt-w-foot {
    display: inline-block;
    margin-top: 12px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--subtle);
    letter-spacing: 0.06em;
    text-decoration: none;
  }

  .qt-w-foot:hover {
    color: var(--ink);
  }
</style>
