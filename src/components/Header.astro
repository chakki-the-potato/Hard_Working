---
import { SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL;

const navItems = ['Programming', 'Thinking', 'Design'];

// 현재 경로로 active 탭 감지
const currentPath = Astro.url.pathname;
---

<header class="site-header sticky top-0 z-50">
  <div class="header-inner">

    <!-- 왼쪽: 로고 -->
    <div class="header-left">
      <a href={base} class="header-logo">
        <img src={`${base}favicon.png`} alt="logo" width="24" height="24" />
        {SITE_TITLE}
      </a>
    </div>

    <!-- 오른쪽: 태그 네비 + 구독하기 + 소개 + 검색 -->
    <div class="header-right">
      <nav class="header-nav" aria-label="카테고리">
        {navItems.map((item) => {
          const href = `${base}tags/${item}/`;
          const isActive = currentPath.startsWith(`${base}tags/${item}`);
          return (
            <a
              href={href}
              class={`header-nav-link${isActive ? ' active' : ''}`}
            >
              {item}
            </a>
          );
        })}
      </nav>
      <a href={`${base}rss.xml`} class="header-subscribe">
        구독하기
      </a>
      <a
        href={`${base}about/`}
        class="header-about"
      >
        소개
      </a>
      <a
        href={`${base}search/`}
        class="header-search"
        aria-label="검색"
      >
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </a>
    </div>

  </div>
</header>

<style>
  .site-header {
    background: var(--color-bg);
    width: 100%;
  }

  .header-inner {
    max-width: 1024px;
    margin: 0 auto;
    padding: 0 20px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  /* 로고 */
  .header-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 700;
    color: var(--color-heading);
    text-decoration: none;
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }

  .header-logo img {
    width: 24px;
    height: 24px;
  }

  /* 왼쪽 그룹 */
  .header-left {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  /* 태그 네비 */
  .header-nav {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-right: 8px;
  }

  .header-nav-link {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    font-size: 15px;
    font-weight: 600;
    color: rgba(3, 18, 40, 0.5);
    text-decoration: none;
    border-radius: 8px;
    transition: color 0.15s, background-color 0.15s;
    white-space: nowrap;
  }

  .header-nav-link:hover {
    color: var(--color-heading);
    background-color: var(--color-bg-badge);
  }

  .header-nav-link.active {
    color: var(--color-heading);
    background-color: var(--color-bg-badge);
  }

  /* 오른쪽 그룹 */
  .header-right {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  /* 구독하기 버튼 */
  .header-subscribe {
    display: inline-flex;
    align-items: center;
    padding: 7px 16px;
    font-size: 14px;
    font-weight: 600;
    color: #fff;
    background-color: var(--color-cta);
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.15s;
    white-space: nowrap;
  }

  .header-subscribe:hover {
    opacity: 0.85;
  }

  /* 소개 링크 */
  .header-about {
    display: inline-flex;
    align-items: center;
    padding: 7px 12px;
    font-size: 14px;
    font-weight: 600;
    color: rgba(3, 18, 40, 0.5);
    text-decoration: none;
    border-radius: 8px;
    transition: color 0.15s, background-color 0.15s;
  }

  .header-about:hover {
    color: var(--color-heading);
    background-color: var(--color-bg-badge);
  }

  /* 검색 아이콘 */
  .header-search {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--color-muted);
    text-decoration: none;
    border-radius: 8px;
    transition: color 0.15s, background-color 0.15s;
  }

  .header-search:hover {
    color: var(--color-heading);
    background-color: var(--color-bg-badge);
  }

  /* 모바일 */
  @media (max-width: 640px) {
    .header-nav {
      display: none;
    }
    .header-about {
      display: none;
    }
    .header-inner {
      padding: 0 16px;
    }
  }
</style>
