---
import ThemeToggle from './ThemeToggle.astro';
import { SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL;
---

<header class="sticky top-0 z-50 backdrop-blur-md border-b" style="background-color: color-mix(in srgb, var(--bg-primary) 85%, transparent); border-color: var(--border);">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href={base} class="text-lg font-bold" style="color: var(--text-primary);">
      {SITE_TITLE}
    </a>
    <div class="flex items-center gap-2">
      <a
        href={`${base}search`}
        class="p-2 rounded-lg transition-colors"
        style="color: var(--text-secondary);"
        aria-label="검색"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>
