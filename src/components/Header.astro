---
import { SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL;
---

<header class="sticky top-0 z-50 border-b bg-white" style="border-color: var(--border);">
  <div class="max-w-5xl mx-auto px-5 h-14 flex items-center justify-between">
    <div class="flex items-center gap-6">
      <a href={base} class="flex items-center gap-2 text-base font-bold tracking-tight" style="color: var(--text-primary);">
        <img src={`${base}favicon.png`} alt="logo" class="w-7 h-7" />
        {SITE_TITLE}
      </a>
      <span style="color: var(--border);">|</span>
      <a
        href={`${base}about/`}
        class="text-sm transition-opacity hover:opacity-60"
        style="color: var(--text-secondary);"
      >
        소개
      </a>
    </div>
    <a
      href={`${base}search/`}
      class="p-2 rounded-lg transition-opacity hover:opacity-60"
      style="color: var(--text-secondary);"
      aria-label="검색"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
    </a>
  </div>
</header>
