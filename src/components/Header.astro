---
import { SITE_TITLE } from '../consts';

const base = import.meta.env.BASE_URL;
const navItems = ['Programming', 'Thinking', 'Design', 'Ideas'] as const;
const currentPath = Astro.url.pathname;

function isActive(item: string) {
  if (item === 'Ideas') {
    return currentPath.startsWith(`${base}ideas`);
  }
  return currentPath.startsWith(`${base}tags/${item}`);
}

function navHref(item: string) {
  if (item === 'Ideas') return `${base}ideas/`;
  return `${base}tags/${item}/`;
}
---

<header class="qt-header">
  <div class="qt-header-inner">
    <div class="qt-header-left">
      <a href={base} class="qt-logo" aria-label={SITE_TITLE}>
        <img src={`${base}favicon.png`} width="22" height="22" alt="" class="qt-logo-img" />
        <span class="qt-logo-name">Hard_Working</span>
      </a>
      <span class="qt-logo-version">v.02 / 2026</span>
    </div>

    <div class="qt-header-right">
      <nav class="qt-nav" aria-label="카테고리">
        {navItems.map((item) => (
          <a
            href={navHref(item)}
            class:list={['qt-nav-link', { 'is-active': isActive(item) }]}
          >
            {item}
          </a>
        ))}
      </nav>

      <span class="qt-divider" aria-hidden="true"></span>

      <button type="button" class="qt-search" data-cmdk-trigger aria-label="글 검색">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <path d="M21 21l-4.3-4.3"/>
        </svg>
        <span class="qt-search-label">글 검색…</span>
        <span class="qt-key">⌘K</span>
      </button>

      <a href={`${base}search/`} class="qt-search-mobile" aria-label="검색">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <path d="M21 21l-4.3-4.3"/>
        </svg>
      </a>

      <a
        href={`${base}about/`}
        class:list={['qt-about', { 'is-active': currentPath.startsWith(`${base}about`) }]}
      >
        소개
      </a>

      <a href={`${base}rss.xml`} class="qt-subscribe">구독</a>
    </div>
  </div>
</header>

<style>
  .qt-header {
    height: 56px;
    padding: 0 32px;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 80%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .qt-header-inner {
    height: 100%;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  /* 좌측 */
  .qt-header-left {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .qt-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--ink);
    text-decoration: none;
  }

  .qt-logo-img {
    display: block;
  }

  .qt-logo-name {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .qt-logo-version {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--subtle);
    letter-spacing: 0.1em;
  }

  /* 우측 */
  .qt-header-right {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .qt-nav {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 13px;
    font-weight: 500;
  }

  .qt-nav-link {
    padding: 6px 12px;
    border-radius: 6px;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s, background-color 0.15s;
  }

  .qt-nav-link:hover {
    color: var(--ink);
  }

  .qt-nav-link.is-active {
    color: var(--ink);
    background: var(--bg-alt);
    font-weight: 600;
  }

  .qt-divider {
    width: 1px;
    height: 14px;
    background: var(--border);
    margin: 0 4px;
  }

  /* 검색 박스 */
  .qt-search {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 32px;
    min-width: 200px;
    padding: 0 10px;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: 7px;
    color: var(--muted);
    font-size: 12.5px;
    font-family: inherit;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.15s, background-color 0.15s;
  }

  .qt-search:hover {
    border-color: var(--border-strong);
    color: var(--ink);
  }

  .qt-search-label {
    flex: 1;
    text-align: left;
  }

  .qt-key {
    font-family: var(--font-mono);
    font-size: 10.5px;
    padding: 1px 5px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  /* 모바일 검색 아이콘 */
  .qt-search-mobile {
    display: none;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: 1px solid var(--border);
    border-radius: 7px;
    background: var(--bg-alt);
    color: var(--muted);
    text-decoration: none;
  }

  .qt-about {
    padding: 6px 10px;
    color: var(--muted);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    border-radius: 6px;
    transition: color 0.15s, background-color 0.15s;
  }

  .qt-about:hover,
  .qt-about.is-active {
    color: var(--ink);
    background: var(--bg-alt);
    font-weight: 600;
  }

  .qt-subscribe {
    margin-left: 4px;
    padding: 7px 14px;
    font-size: 13px;
    font-weight: 600;
    color: var(--bg-elev);
    background: var(--ink);
    border: none;
    border-radius: 7px;
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: opacity 0.15s;
  }

  .qt-subscribe:hover {
    opacity: 0.85;
  }

  /* 반응형 */
  @media (max-width: 1024px) {
    .qt-header {
      padding: 0 20px;
    }
    .qt-search-label {
      display: none;
    }
    .qt-search {
      min-width: 0;
      width: 32px;
      padding: 0;
      justify-content: center;
    }
    .qt-search .qt-key {
      display: none;
    }
  }

  @media (max-width: 720px) {
    .qt-nav,
    .qt-divider,
    .qt-about,
    .qt-logo-version {
      display: none;
    }
    .qt-search {
      display: none;
    }
    .qt-search-mobile {
      display: inline-flex;
    }
  }

  @media (max-width: 420px) {
    .qt-subscribe {
      display: none;
    }
  }
</style>
