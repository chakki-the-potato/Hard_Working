<div class="qt-reading-progress" aria-hidden="true">
  <span></span>
</div>

<style>
  .qt-reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    z-index: 60;
    pointer-events: none;
  }

  .qt-reading-progress > span {
    display: block;
    height: 100%;
    width: 100%;
    background: var(--accent);
    transform: scaleX(var(--p, 0));
    transform-origin: left center;
    transition: transform 80ms linear;
  }

  @media (prefers-reduced-motion: reduce) {
    .qt-reading-progress > span {
      transition: none;
    }
  }
</style>

<script>
  let ticking = false;
  let initialized = false;

  function update() {
    ticking = false;
    const bar = document.querySelector<HTMLElement>('.qt-reading-progress > span');
    if (!bar) return;
    const doc = document.documentElement;
    const scrollTop = doc.scrollTop || document.body.scrollTop;
    const scrollHeight = doc.scrollHeight - doc.clientHeight;
    const p = scrollHeight > 0 ? Math.min(1, Math.max(0, scrollTop / scrollHeight)) : 0;
    bar.style.setProperty('--p', String(p));
  }

  function onScroll() {
    if (!ticking) {
      requestAnimationFrame(update);
      ticking = true;
    }
  }

  function init() {
    if (!initialized) {
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      initialized = true;
    }
    update();
  }

  document.addEventListener('astro:page-load', init);
</script>
