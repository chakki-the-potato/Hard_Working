---
import BaseLayout from './BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import PostListRow from '../components/PostListRow.astro';
import HeroDriftBg from '../components/HeroDriftBg.astro';
import SidebarAbout from '../components/widgets/SidebarAbout.astro';
import SidebarCategoryStats from '../components/widgets/SidebarCategoryStats.astro';
import SidebarTagCloud from '../components/widgets/SidebarTagCloud.astro';
import SidebarActivity from '../components/widgets/SidebarActivity.astro';
import IdeasStrip from '../components/widgets/IdeasStrip.astro';
import type { ActivityEntry } from '../components/widgets/SidebarActivity.astro';
import type { IdeaCard } from '../components/widgets/IdeasStrip.astro';
import { SITE_TITLE, SITE_DESCRIPTION, FEATURED_COUNT, POSTS_PER_PAGE } from '../consts';
import type { Category } from '../lib/categories';

interface ArticlePost {
  id: string;
  data: {
    title: string;
    description: string;
    pubDate: Date;
    category: Category;
    tags: string[];
    heroImage?: string;
  };
}

interface ArchivePage {
  data: ArticlePost[];
  currentPage: number;
  lastPage: number;
  url: { prev?: string; next?: string; current: string };
}

interface Props {
  featured: ArticlePost[];
  archivePage: ArchivePage;
  totalArticles: number;
  totalTags: number;
  lastUpdate?: Date;
  categoryCounts: Record<Category, number>;
  topTags: Array<{ tag: string; count: number }>;
  recentActivity: ActivityEntry[];
  recentIdeas: IdeaCard[];
}

const {
  featured,
  archivePage,
  totalArticles,
  totalTags,
  lastUpdate,
  categoryCounts,
  topTags,
  recentActivity,
  recentIdeas,
} = Astro.props;

const pad2 = (n: number) => String(n).padStart(2, '0');

const featuredCountLabel = pad2(featured.length);
const totalLabel = pad2(totalArticles);

const archivePageLabel = pad2(archivePage.currentPage);
const archiveLastLabel = pad2(archivePage.lastPage);

const lastUpdateLabel = lastUpdate
  ? `${lastUpdate.getFullYear()}.${pad2(lastUpdate.getMonth() + 1)}.${pad2(lastUpdate.getDate())}`
  : '';

const archiveStartIndex = FEATURED_COUNT + (archivePage.currentPage - 1) * POSTS_PER_PAGE;
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} noPadding={true}>
  <section class="qt-hero" id="qt-hero" transition:persist="qt-hero">
    <div class="qt-hero-bg-wrap" id="qt-hero-bg-wrap">
      <HeroDriftBg strength={1} />
    </div>
    <div class="qt-hero-inner">
      <aside class="qt-hero-mark" aria-hidden="true">
        <span class="qt-hero-mark-num">/STUDY</span>
        <span class="qt-hero-mark-year">JOURNAL</span>
      </aside>
      <div class="qt-hero-syslog">
        SYS_LOG<br />
        <span class="qt-hero-syslog-time" id="qt-syslog-time">{lastUpdateLabel}</span><br />
        <span class="qt-hero-online">● ONLINE</span>
      </div>
      <span class="qt-hero-mono">╱╱  HARD_WORKING / V.02</span>
      <h1 class="qt-hero-title">
        세상은 넓고도<br />
        넓지만 내 <span class="qt-hero-accent">자리</span>는 있다.
      </h1>
      <p class="qt-hero-desc">
        Programming · Thinking · Design — 매일의 학습 기록.
      </p>
      <div class="qt-hero-stats">
        <span><strong>{totalArticles}</strong> articles</span>
        <span><strong>{totalTags}</strong> tags</span>
        <span>updated <strong>daily</strong></span>
      </div>
    </div>
  </section>

  <main class="qt-home-shell">
    <div class="qt-home-content">
      {featured.length > 0 && (
        <div class="qt-featured-wrap" transition:persist="qt-featured">
          <div class="qt-section-head">
            <h2 class="qt-section-mono">// FEATURED</h2>
            <span class="qt-section-count">{featuredCountLabel} OF {totalLabel}</span>
          </div>
          <div class="qt-feat-list">
            {featured.map((post, i) => (
              <PostCard
                id={post.id}
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                category={post.data.category}
                tags={post.data.tags}
                num={totalArticles - i}
              />
            ))}
          </div>
        </div>
      )}

      <IdeasStrip ideas={recentIdeas} />

      {archivePage.data.length > 0 && (
        <div transition:name="qt-archive" transition:animate="fade">
          <div class:list={['qt-section-head', { 'qt-section-archive': featured.length > 0 || recentIdeas.length > 0 }]}>
            <h2 class="qt-section-mono">// ARCHIVE</h2>
            <span class="qt-section-count">PAGE {archivePageLabel} OF {archiveLastLabel}</span>
          </div>
          <div class="qt-archive-list">
            {archivePage.data.map((post, i) => (
              <PostListRow
                id={post.id}
                title={post.data.title}
                pubDate={post.data.pubDate}
                category={post.data.category}
                tags={post.data.tags}
                num={totalArticles - archiveStartIndex - i}
              />
            ))}
          </div>

          {archivePage.lastPage > 1 && (
            <nav class="qt-archive-pager" aria-label="페이지네이션">
              {archivePage.url.prev ? (
                <a href={archivePage.url.prev} class="qt-pager-arrow">← PREV</a>
              ) : (
                <span class="qt-pager-arrow is-disabled">← PREV</span>
              )}
              <span class="qt-pager-mono">{archivePageLabel} / {archiveLastLabel}</span>
              {archivePage.url.next ? (
                <a href={archivePage.url.next} class="qt-pager-arrow is-next">NEXT →</a>
              ) : (
                <span class="qt-pager-arrow is-next is-disabled">NEXT →</span>
              )}
            </nav>
          )}
        </div>
      )}

      {totalArticles === 0 && (
        <p class="qt-empty">아직 작성된 글이 없습니다.</p>
      )}
    </div>

    <aside class="qt-home-aside" aria-label="사이드바">
      <SidebarAbout />
      <SidebarCategoryStats counts={categoryCounts} />
      {topTags.length > 0 && <SidebarTagCloud tags={topTags} />}
      {recentActivity.length > 0 && <SidebarActivity entries={recentActivity} />}
    </aside>
  </main>
</BaseLayout>

<script>
  // ARCHIVE 페이지 전환 시 스크롤 위치 유지
  // (View Transitions 기본 동작은 맨 위로 리셋)
  let savedScrollY: number | null = null;
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement | null;
    if (target?.closest('a.qt-pager-arrow')) {
      savedScrollY = window.scrollY;
    }
  });
  document.addEventListener('astro:after-swap', () => {
    if (savedScrollY !== null) {
      window.scrollTo({ top: savedScrollY, left: 0, behavior: 'instant' });
      savedScrollY = null;
    }
  });

  // 스크롤 시차 — 히어로 배경만 천천히 따라옴
  const heroSection = document.getElementById('qt-hero');
  const bgWrap = document.getElementById('qt-hero-bg-wrap');
  if (heroSection && bgWrap) {
    let raf = 0;
    const onScroll = () => {
      if (raf) return;
      raf = requestAnimationFrame(() => {
        const y = window.scrollY || 0;
        bgWrap.style.transform = `translateY(${y * 0.4}px)`;
        raf = 0;
      });
    };
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // SYS_LOG 시계 — 현재 KST 시간 노출
  const timeEl = document.getElementById('qt-syslog-time');
  if (timeEl) {
    function fmt() {
      const now = new Date();
      const yyyy = now.getFullYear();
      const mm = String(now.getMonth() + 1).padStart(2, '0');
      const dd = String(now.getDate()).padStart(2, '0');
      const hh = String(now.getHours()).padStart(2, '0');
      const mi = String(now.getMinutes()).padStart(2, '0');
      return `${yyyy}.${mm}.${dd} / ${hh}:${mi} KST`;
    }
    timeEl.textContent = fmt();
    setInterval(() => { timeEl.textContent = fmt(); }, 30_000);
  }
</script>

<style>
  /* ── Hero ── */
  .qt-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .qt-hero-bg-wrap {
    position: absolute;
    inset: 0;
    will-change: transform;
  }

  .qt-hero-inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 88px 36px 56px;
  }

  .qt-hero-syslog {
    position: absolute;
    top: 28px;
    right: 36px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--subtle);
    letter-spacing: 0.06em;
    text-align: right;
    line-height: 1.7;
  }

  .qt-hero-syslog-time {
    color: var(--muted);
  }

  .qt-hero-online {
    color: var(--accent);
  }

  .qt-hero-mono {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.12em;
    margin-bottom: 24px;
  }

  .qt-hero-title {
    font-size: calc(76px * var(--h-scale));
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.05em;
    color: var(--ink);
    margin: 0;
    max-width: 920px;
  }

  .qt-hero-mark {
    position: absolute;
    top: 50%;
    right: 36px;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    font-family: var(--font-mono);
    color: color-mix(in srgb, var(--ink) 6%, transparent);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.85;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .qt-hero-mark-num {
    font-size: clamp(140px, 20vw, 260px);
  }

  .qt-hero-mark-year {
    font-size: clamp(36px, 5vw, 70px);
    margin-top: 12px;
    opacity: 0.7;
  }

  .qt-hero-accent {
    color: var(--accent);
  }

  .qt-hero-desc {
    font-size: 17px;
    line-height: 1.6;
    color: var(--muted);
    margin: 22px 0 0;
    max-width: 540px;
    font-weight: 500;
  }

  .qt-hero-stats {
    margin-top: 28px;
    display: flex;
    gap: 28px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .qt-hero-stats strong {
    color: var(--ink);
    font-weight: 600;
  }

  /* ── Main shell (grid) ── */
  .qt-home-shell {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 36px 0;
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 56px;
    align-items: start;
  }

  .qt-home-content {
    min-width: 0;
  }

  .qt-home-aside {
    display: flex;
    flex-direction: column;
    gap: 28px;
    padding-left: 4px;
  }

  .qt-section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-strong);
    margin-bottom: 4px;
  }

  .qt-section-archive {
    margin-top: 56px;
  }

  .qt-section-mono {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--ink);
    margin: 0;
    letter-spacing: 0.14em;
  }

  .qt-section-count {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--subtle);
    letter-spacing: 0.06em;
  }

  .qt-feat-list,
  .qt-archive-list {
    display: flex;
    flex-direction: column;
  }

  .qt-archive-pager {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 0;
    border-top: 1px solid var(--border-hair);
    margin-top: 16px;
    gap: 16px;
  }

  .qt-pager-arrow {
    display: inline-flex;
    align-items: center;
    padding: 7px 12px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 12.5px;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.15s, border-color 0.15s;
  }

  .qt-pager-arrow:hover:not(.is-disabled) {
    color: var(--ink);
    border-color: var(--border-strong);
    font-weight: 600;
  }

  .qt-pager-arrow.is-disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .qt-pager-mono {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.06em;
  }

  .qt-empty {
    text-align: center;
    padding: 64px 0;
    color: var(--muted);
    font-size: 15px;
  }

  /* ── 반응형 ── */
  @media (max-width: 1100px) {
    .qt-hero-mark {
      top: auto;
      bottom: 24px;
      right: 24px;
      transform: none;
    }
    .qt-hero-mark-num {
      font-size: clamp(100px, 18vw, 180px);
    }
  }

  @media (max-width: 960px) {
    .qt-home-shell {
      grid-template-columns: 1fr;
      gap: 36px;
      padding: 32px 24px 0;
    }
    .qt-home-aside {
      order: 2;
      padding-left: 0;
      padding-top: 28px;
      border-top: 1px solid var(--border-hair);
    }
  }

  @media (max-width: 900px) {
    .qt-hero-inner {
      padding: 72px 24px 48px;
    }
    .qt-hero-title {
      font-size: calc(56px * var(--h-scale));
    }
  }

  @media (max-width: 720px) {
    .qt-hero-syslog {
      display: none;
    }
    .qt-hero-title {
      font-size: calc(44px * var(--h-scale));
      letter-spacing: -0.04em;
    }
    .qt-hero-stats {
      gap: 16px;
      flex-wrap: wrap;
      font-size: 11px;
    }
    .qt-hero-mark {
      bottom: 16px;
      right: 16px;
    }
    .qt-hero-mark-num {
      font-size: 96px;
    }
    .qt-hero-mark-year {
      font-size: 28px;
    }
  }

  @media (max-width: 480px) {
    .qt-hero-inner {
      padding: 56px 20px 40px;
    }
    .qt-hero-title {
      font-size: calc(36px * var(--h-scale));
    }
    .qt-home-shell {
      padding: 24px 20px 0;
    }
    .qt-section-archive {
      margin-top: 40px;
    }
  }
</style>
