---
import BaseLayout from './BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import PostListRow from '../components/PostListRow.astro';
import HeroDriftBg from '../components/HeroDriftBg.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

interface ArticlePost {
  id: string;
  data: {
    title: string;
    description: string;
    pubDate: Date;
    tags: string[];
    heroImage?: string;
  };
}

interface Props {
  allPosts: ArticlePost[];
  totalTags: number;
  pageSize?: number;
}

const { allPosts, totalTags, pageSize = 8 } = Astro.props;

const featuredCount = 3;
const featured = allPosts.slice(0, featuredCount);
const archive = allPosts.slice(featuredCount);

const totalArticles = allPosts.length;
const featuredCountLabel = String(Math.min(featuredCount, totalArticles)).padStart(2, '0');
const totalLabel = String(totalArticles).padStart(2, '0');

const lastUpdate = allPosts[0]?.data.pubDate
  ? `${allPosts[0].data.pubDate.getFullYear()}.${String(allPosts[0].data.pubDate.getMonth() + 1).padStart(2, '0')}.${String(allPosts[0].data.pubDate.getDate()).padStart(2, '0')}`
  : '';
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} noPadding={true}>
  <section class="qt-hero" id="qt-hero">
    <div class="qt-hero-bg-wrap" id="qt-hero-bg-wrap">
      <HeroDriftBg strength={1} />
    </div>
    <div class="qt-hero-inner">
      <div class="qt-hero-syslog">
        SYS_LOG<br />
        <span class="qt-hero-syslog-time" id="qt-syslog-time">{lastUpdate}</span><br />
        <span class="qt-hero-online">● ONLINE</span>
      </div>
      <span class="qt-hero-mono">╱╱  HARD_WORKING / V.02</span>
      <h1 class="qt-hero-title">
        공부의 결을<br />
        한 편씩 <span class="qt-hero-accent">기록</span>합니다.
      </h1>
      <p class="qt-hero-desc">
        Programming · Thinking · Design — 매일의 학습 기록.
      </p>
      <div class="qt-hero-stats">
        <span><strong>{totalArticles}</strong> articles</span>
        <span><strong>{totalTags}</strong> tags</span>
        <span>updated <strong>daily</strong></span>
      </div>
    </div>
  </section>

  <main class="qt-home-main">
    {featured.length > 0 && (
      <>
        <div class="qt-section-head">
          <h2 class="qt-section-mono">// FEATURED</h2>
          <span class="qt-section-count">{featuredCountLabel} OF {totalLabel}</span>
        </div>
        <div class="qt-feat-list">
          {featured.map((post, i) => (
            <PostCard
              id={post.id}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              num={i + 1}
            />
          ))}
        </div>
      </>
    )}

    {archive.length > 0 && (
      <>
        <div class="qt-section-head qt-section-archive">
          <h2 class="qt-section-mono">// ARCHIVE</h2>
          <span class="qt-section-count" id="qt-archive-count">
            {String(Math.min(pageSize, archive.length)).padStart(2, '0')} / {String(archive.length).padStart(2, '0')}
          </span>
        </div>
        <div class="qt-archive-list" id="qt-archive-list" data-page-size={pageSize}>
          {archive.map((post, i) => (
            <div
              class="qt-archive-item"
              data-index={i}
              data-visible={i < pageSize ? 'true' : 'false'}
              hidden={i >= pageSize}
            >
              <PostListRow
                id={post.id}
                title={post.data.title}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                num={featuredCount + i + 1}
              />
            </div>
          ))}
        </div>

        {archive.length > pageSize && (
          <div class="qt-more-wrap">
            <button type="button" class="qt-more-btn" id="qt-more-btn" data-step={pageSize}>
              더 보기
              <span class="qt-more-mono" id="qt-more-mono">+{Math.min(pageSize, archive.length - pageSize)}</span>
            </button>
          </div>
        )}
      </>
    )}

    {allPosts.length === 0 && (
      <p class="qt-empty">아직 작성된 글이 없습니다.</p>
    )}
  </main>
</BaseLayout>

<script>
  // 스크롤 시차 — 히어로 배경만 천천히 따라옴
  const heroSection = document.getElementById('qt-hero');
  const bgWrap = document.getElementById('qt-hero-bg-wrap');
  if (heroSection && bgWrap) {
    let raf = 0;
    const onScroll = () => {
      if (raf) return;
      raf = requestAnimationFrame(() => {
        const y = window.scrollY || 0;
        bgWrap.style.transform = `translateY(${y * 0.4}px)`;
        raf = 0;
      });
    };
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // SYS_LOG 시계 — 현재 KST 시간 노출
  const timeEl = document.getElementById('qt-syslog-time');
  if (timeEl) {
    function fmt() {
      const now = new Date();
      const yyyy = now.getFullYear();
      const mm = String(now.getMonth() + 1).padStart(2, '0');
      const dd = String(now.getDate()).padStart(2, '0');
      const hh = String(now.getHours()).padStart(2, '0');
      const mi = String(now.getMinutes()).padStart(2, '0');
      return `${yyyy}.${mm}.${dd} / ${hh}:${mi} KST`;
    }
    timeEl.textContent = fmt();
    setInterval(() => { timeEl.textContent = fmt(); }, 30_000);
  }

  // 더 보기 — 클라이언트 페이지네이션
  const moreBtn = document.getElementById('qt-more-btn') as HTMLButtonElement | null;
  const archiveList = document.getElementById('qt-archive-list');
  const archiveCount = document.getElementById('qt-archive-count');
  const moreMono = document.getElementById('qt-more-mono');
  if (moreBtn && archiveList) {
    const step = Number(moreBtn.dataset.step) || 8;
    moreBtn.addEventListener('click', () => {
      const items = archiveList.querySelectorAll<HTMLElement>('.qt-archive-item');
      const total = items.length;
      let visibleCount = 0;
      items.forEach((el) => { if (el.dataset.visible === 'true') visibleCount++; });

      const nextEnd = Math.min(visibleCount + step, total);
      for (let i = visibleCount; i < nextEnd; i++) {
        items[i].dataset.visible = 'true';
        items[i].hidden = false;
      }

      if (archiveCount) {
        archiveCount.textContent = `${String(nextEnd).padStart(2, '0')} / ${String(total).padStart(2, '0')}`;
      }

      if (nextEnd >= total) {
        moreBtn.style.display = 'none';
      } else if (moreMono) {
        moreMono.textContent = `+${Math.min(step, total - nextEnd)}`;
      }
    });
  }
</script>

<style>
  /* ── Hero ── */
  .qt-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .qt-hero-bg-wrap {
    position: absolute;
    inset: 0;
    will-change: transform;
  }

  .qt-hero-inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 88px 36px 56px;
  }

  .qt-hero-syslog {
    position: absolute;
    top: 28px;
    right: 36px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--subtle);
    letter-spacing: 0.06em;
    text-align: right;
    line-height: 1.7;
  }

  .qt-hero-syslog-time {
    color: var(--muted);
  }

  .qt-hero-online {
    color: var(--accent);
  }

  .qt-hero-mono {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.12em;
    margin-bottom: 24px;
  }

  .qt-hero-title {
    font-size: calc(76px * var(--h-scale));
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.05em;
    color: var(--ink);
    margin: 0;
    max-width: 920px;
  }

  .qt-hero-accent {
    color: var(--accent);
  }

  .qt-hero-desc {
    font-size: 17px;
    line-height: 1.6;
    color: var(--muted);
    margin: 22px 0 0;
    max-width: 540px;
    font-weight: 500;
  }

  .qt-hero-stats {
    margin-top: 28px;
    display: flex;
    gap: 28px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .qt-hero-stats strong {
    color: var(--ink);
    font-weight: 600;
  }

  /* ── Main ── */
  .qt-home-main {
    max-width: 1040px;
    margin: 0 auto;
    padding: 40px 36px 0;
  }

  .qt-section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-strong);
    margin-bottom: 4px;
  }

  .qt-section-archive {
    margin-top: 56px;
  }

  .qt-section-mono {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--ink);
    margin: 0;
    letter-spacing: 0.14em;
  }

  .qt-section-count {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--subtle);
    letter-spacing: 0.06em;
  }

  .qt-feat-list,
  .qt-archive-list {
    display: flex;
    flex-direction: column;
  }

  .qt-archive-item[hidden] {
    display: none;
  }

  .qt-more-wrap {
    display: flex;
    justify-content: center;
    margin-top: 32px;
  }

  .qt-more-btn {
    padding: 10px 22px;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    background: var(--bg-elev);
    border: 1px solid var(--border-strong);
    border-radius: 7px;
    cursor: pointer;
    font-family: inherit;
    letter-spacing: -0.01em;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background-color 0.15s;
  }

  .qt-more-btn:hover {
    background: var(--bg-alt);
  }

  .qt-more-mono {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .qt-empty {
    text-align: center;
    padding: 64px 0;
    color: var(--muted);
    font-size: 15px;
  }

  /* ── 반응형 ── */
  @media (max-width: 900px) {
    .qt-hero-inner {
      padding: 72px 24px 48px;
    }
    .qt-hero-title {
      font-size: calc(56px * var(--h-scale));
    }
    .qt-home-main {
      padding: 32px 24px 0;
    }
  }

  @media (max-width: 720px) {
    .qt-hero-syslog {
      display: none;
    }
    .qt-hero-title {
      font-size: calc(44px * var(--h-scale));
      letter-spacing: -0.04em;
    }
    .qt-hero-stats {
      gap: 16px;
      flex-wrap: wrap;
      font-size: 11px;
    }
  }

  @media (max-width: 480px) {
    .qt-hero-inner {
      padding: 56px 20px 40px;
    }
    .qt-hero-title {
      font-size: calc(36px * var(--h-scale));
    }
    .qt-home-main {
      padding: 24px 20px 0;
    }
    .qt-section-archive {
      margin-top: 40px;
    }
  }
</style>
