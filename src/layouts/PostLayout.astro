---
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import PostListRow from '../components/PostListRow.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import { categoryLabel, type Category } from '../lib/categories';

interface Props {
  id: string;
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: Category;
  tags: string[];
  heroImage?: string;
  demoUrl?: string;
  repoUrl?: string;
  role?: string;
  period?: string;
  outcome?: string;
}

const {
  id,
  title,
  description,
  pubDate,
  updatedDate,
  category,
  tags,
  demoUrl,
  repoUrl,
  role,
  period,
  outcome,
} = Astro.props;

const isWorks = category === 'works';
const hasWorksMeta = isWorks && Boolean(demoUrl || repoUrl || role || period || outcome);
const repoLabel = repoUrl ? repoUrl.replace(/^https?:\/\//, '').replace(/\/$/, '') : '';
const demoLabel = demoUrl ? demoUrl.replace(/^https?:\/\//, '').replace(/\/$/, '') : '';
const base = import.meta.env.BASE_URL;

const cat = categoryLabel(category);
const sub = tags[0] ?? '';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedAll = [...allPosts].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const numberMap = new Map<string, number>();
[...sortedAll].reverse().forEach((p, i) => numberMap.set(p.id, i + 1));
const num = numberMap.get(id);
const numLabel = num != null ? String(num).padStart(3, '0') : '';

const dateLabel = `${pubDate.getFullYear()}.${String(pubDate.getMonth() + 1).padStart(2, '0')}.${String(pubDate.getDate()).padStart(2, '0')}`;
const updatedLabel = updatedDate
  ? `${updatedDate.getFullYear()}.${String(updatedDate.getMonth() + 1).padStart(2, '0')}.${String(updatedDate.getDate()).padStart(2, '0')}`
  : '';

// 읽기 시간 추정 (대략 — 한글 600자/분 기준은 본문이 없으니 대략 5분 고정)
const readLabel = '5분';

// 관련 글 — 같은 카테고리 최근 3개 (현재 글 제외)
const related = sortedAll
  .filter((p) => p.id !== id && p.data.category === category)
  .slice(0, 3);

// 번호 오름차순 (№001 → 최신) 으로 인접 글 계산
const sortedByNum = [...sortedAll].reverse();
const idx = sortedByNum.findIndex((p) => p.id === id);
const prevPost = idx > 0 ? sortedByNum[idx - 1] : null;
const nextPost = idx >= 0 && idx < sortedByNum.length - 1 ? sortedByNum[idx + 1] : null;
---

<BaseLayout title={title} description={description} noPadding={true}>
  <ReadingProgress />
  <div class="qt-post-wrap">
    <section class="qt-post-crumb">
      <span>HOME / {cat ? cat.toUpperCase() : 'NOTE'}{numLabel ? ` / №${numLabel}` : ''}</span>
      <span>{dateLabel}{updatedLabel ? ` / UPD ${updatedLabel}` : ''}</span>
    </section>

    <article class="qt-post">
      <span class="qt-post-mono">// {numLabel || '—'} · {(cat || 'NOTE').toUpperCase()}{sub ? ` / ${sub.toUpperCase()}` : ''}</span>
      <h1 class="qt-post-title">{title}</h1>
      <div class="qt-post-meta">
        {dateLabel} ─ {readLabel}
      </div>
      <p class="qt-post-lede">{description}</p>

      {hasWorksMeta && (
        <dl class="qt-post-works-meta" aria-label="Works metadata">
          {role && (
            <div class="qt-works-row">
              <dt>ROLE</dt>
              <dd>{role}</dd>
            </div>
          )}
          {period && (
            <div class="qt-works-row">
              <dt>PERIOD</dt>
              <dd>{period}</dd>
            </div>
          )}
          {outcome && (
            <div class="qt-works-row">
              <dt>OUTCOME</dt>
              <dd>{outcome}</dd>
            </div>
          )}
          {demoUrl && (
            <div class="qt-works-row">
              <dt>DEMO</dt>
              <dd>
                <a href={demoUrl} target="_blank" rel="noopener noreferrer">{demoLabel}</a>
              </dd>
            </div>
          )}
          {repoUrl && (
            <div class="qt-works-row">
              <dt>REPO</dt>
              <dd>
                <a href={repoUrl} target="_blank" rel="noopener noreferrer">{repoLabel}</a>
              </dd>
            </div>
          )}
        </dl>
      )}

      <div class="prose">
        <slot />
      </div>

      <a href={base} class="qt-post-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        목록으로
      </a>

      {related.length > 0 && (
        <section class="qt-post-related">
          <span class="qt-post-related-mono">// RELATED</span>
          {related.map((p) => (
            <PostListRow
              id={p.id}
              title={p.data.title}
              pubDate={p.data.pubDate}
              category={p.data.category}
              tags={p.data.tags}
              num={numberMap.get(p.id)}
            />
          ))}
        </section>
      )}

      {(prevPost || nextPost) && (
        <nav class="qt-post-nav" aria-label="이전·다음 글">
          {prevPost ? (
            <a href={`${base}posts/${prevPost.id}/`} class="qt-post-nav-card qt-post-nav-prev">
              <span class="qt-post-nav-label">← 이전글</span>
              <span class="qt-post-nav-num">№{String(numberMap.get(prevPost.id)).padStart(3, '0')}</span>
              <span class="qt-post-nav-title">{prevPost.data.title}</span>
            </a>
          ) : (
            <div class="qt-post-nav-card qt-post-nav-prev is-disabled" aria-hidden="true">
              <span class="qt-post-nav-label">← 이전글</span>
              <span class="qt-post-nav-empty">처음 글입니다</span>
            </div>
          )}
          {nextPost ? (
            <a href={`${base}posts/${nextPost.id}/`} class="qt-post-nav-card qt-post-nav-next">
              <span class="qt-post-nav-label">다음글 →</span>
              <span class="qt-post-nav-num">№{String(numberMap.get(nextPost.id)).padStart(3, '0')}</span>
              <span class="qt-post-nav-title">{nextPost.data.title}</span>
            </a>
          ) : (
            <div class="qt-post-nav-card qt-post-nav-next is-disabled" aria-hidden="true">
              <span class="qt-post-nav-label">다음글 →</span>
              <span class="qt-post-nav-empty">최신 글입니다</span>
            </div>
          )}
        </nav>
      )}
    </article>
  </div>
</BaseLayout>

<style>
  .qt-post-wrap {
    min-height: 100%;
  }

  .qt-post-crumb {
    padding: 10px 36px;
    border-bottom: 1px solid var(--border-hair);
    background: var(--bg-alt);
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--muted);
    letter-spacing: 0.1em;
    display: flex;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    flex-wrap: wrap;
    gap: 8px;
  }

  .qt-post {
    max-width: var(--content-w);
    margin: 0 auto;
    padding: 32px 28px 0;
  }

  .qt-post-mono {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin-bottom: 18px;
  }

  .qt-post-title {
    font-size: calc(42px * var(--h-scale));
    font-weight: 800;
    line-height: 1.18;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0;
  }

  .qt-post-meta {
    margin-top: 20px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border-strong);
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .qt-post-lede {
    font-size: 19px;
    line-height: 1.65;
    color: var(--ink);
    margin: 32px 0;
    font-weight: 600;
    letter-spacing: -0.015em;
  }

  .qt-post-works-meta {
    display: grid;
    grid-template-columns: max-content 1fr;
    column-gap: 18px;
    row-gap: 8px;
    margin: 0 0 36px;
    padding: 16px 18px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-alt);
    font-family: var(--font-mono);
    font-size: 12.5px;
  }

  .qt-works-row {
    display: contents;
  }

  .qt-post-works-meta dt {
    color: var(--subtle);
    letter-spacing: 0.12em;
    align-self: baseline;
  }

  .qt-post-works-meta dd {
    margin: 0;
    color: var(--ink);
    word-break: break-all;
  }

  .qt-post-works-meta a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
    transition: border-color 0.15s;
  }

  .qt-post-works-meta a:hover {
    border-bottom-color: var(--accent);
  }

  .qt-post-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 56px;
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    border: 1px solid var(--border);
    border-radius: 7px;
    transition: color 0.15s, border-color 0.15s;
  }

  .qt-post-back:hover {
    color: var(--ink);
    border-color: var(--border-strong);
  }

  .qt-post-related {
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  .qt-post-related-mono {
    display: block;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--subtle);
    letter-spacing: 0.12em;
    margin-bottom: 14px;
  }

  .qt-post-nav {
    position: relative;
    margin-top: 40px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .qt-post-nav::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 14px;
    bottom: 14px;
    width: 1px;
    background: var(--border);
    pointer-events: none;
  }

  .qt-post-nav-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 16px 18px;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: background-color 0.15s;
  }

  .qt-post-nav-card:hover {
    background: var(--bg-alt);
  }

  .qt-post-nav-next {
    text-align: right;
  }

  .qt-post-nav-label {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--subtle);
    letter-spacing: 0.12em;
  }

  .qt-post-nav-num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.04em;
  }

  .qt-post-nav-title {
    font-size: 13.5px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.015em;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .qt-post-nav-empty {
    font-size: 13px;
    color: var(--subtle);
  }

  .qt-post-nav-card.is-disabled {
    opacity: 0.5;
    pointer-events: none;
  }

  @media (max-width: 720px) {
    .qt-post-crumb {
      padding: 10px 20px;
      font-size: 10px;
    }
    .qt-post {
      padding: 24px 20px 0;
    }
    .qt-post-title {
      font-size: calc(28px * var(--h-scale));
    }
    .qt-post-lede {
      font-size: 17px;
    }
    .qt-post-works-meta {
      grid-template-columns: 1fr;
      row-gap: 14px;
      padding: 14px 14px;
      font-size: 12px;
    }
    .qt-works-row {
      display: block;
    }
    .qt-post-works-meta dt {
      display: block;
      margin-bottom: 2px;
      font-size: 10.5px;
    }
    .qt-post-nav {
      grid-template-columns: 1fr;
      gap: 10px;
    }
    .qt-post-nav::before {
      left: 14px;
      right: 14px;
      top: 50%;
      bottom: auto;
      width: auto;
      height: 1px;
    }
    .qt-post-nav-next {
      text-align: left;
    }
  }
</style>
