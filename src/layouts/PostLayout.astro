---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  heroImage?: string;
}

const { title, description, pubDate, updatedDate, tags, heroImage } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description}>
  <div class="post-wrapper">
    <article class="post-article">

      <!-- 뒤로 가기 -->
      <a href={base} class="post-back">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        목록으로
      </a>

      <!-- 히어로 이미지 -->
      {heroImage && (
        <div class="post-hero">
          <img src={heroImage} alt={title} />
        </div>
      )}

      <!-- 헤더 -->
      <header class="post-header">
        <h1 class="post-title">{title}</h1>

        <!-- 태그 뱃지 -->
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map((tag) => (
              <a href={`${base}tags/${tag}/`} class="post-tag">#{tag}</a>
            ))}
          </div>
        )}

        <!-- 메타 정보 -->
        <div class="post-meta">
          <time datetime={pubDate.toISOString()}>
            {pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {updatedDate && (
            <span class="post-meta-updated">
              (수정: {updatedDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })})
            </span>
          )}
        </div>
      </header>

      <!-- 본문 -->
      <div class="prose">
        <slot />
      </div>

    </article>
  </div>
</BaseLayout>

<style>
  .post-wrapper {
    display: flex;
    justify-content: center;
    padding: 0 20px;
  }

  .post-article {
    width: 100%;
    max-width: 740px;
    padding-bottom: 80px;
  }

  /* 뒤로 가기 링크 */
  .post-back {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    margin-bottom: 32px;
    transition: opacity 0.15s;
  }
  .post-back:hover {
    opacity: 0.6;
  }

  /* 히어로 이미지 */
  .post-hero {
    margin-bottom: 32px;
    border-radius: 12px;
    overflow: hidden;
  }
  .post-hero img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* 헤더 */
  .post-header {
    margin-bottom: 48px;
  }

  .post-title {
    font-size: 2.75rem;
    font-weight: 700;
    color: var(--color-heading);
    line-height: 1.25;
    letter-spacing: -0.03em;
    margin: 0 0 20px 0;
  }

  /* 태그 */
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .post-tag {
    display: inline-flex;
    align-items: center;
    font-size: 13px;
    font-weight: 600;
    background-color: var(--color-bg-badge);
    color: var(--color-muted);
    border-radius: 8px;
    padding: 3px 10px;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .post-tag:hover {
    opacity: 0.7;
  }

  /* 메타 */
  .post-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    color: var(--color-muted);
  }

  .post-meta-updated {
    color: var(--color-subtle);
  }

  /* prose 내부 첫 요소 margin 제거 */
  .prose > :first-child {
    margin-top: 0 !important;
  }

  /* 반응형 */
  @media (max-width: 768px) {
    .post-wrapper {
      padding: 0 4px;
    }

    .post-title {
      font-size: 2rem;
    }
  }

  @media (max-width: 480px) {
    .post-title {
      font-size: 1.625rem;
    }
  }
</style>
