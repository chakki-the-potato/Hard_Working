---
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import PostListRow from '../components/PostListRow.astro';

interface Props {
  id: string;
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  heroImage?: string;
}

const { id, title, description, pubDate, updatedDate, tags } = Astro.props;
const base = import.meta.env.BASE_URL;

const cat = tags[0] ?? '';
const sub = tags[1] ?? '';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedAll = [...allPosts].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const numberMap = new Map<string, number>();
sortedAll.forEach((p, i) => numberMap.set(p.id, i + 1));
const num = numberMap.get(id);
const numLabel = num != null ? String(num).padStart(3, '0') : '';

const dateLabel = `${pubDate.getFullYear()}.${String(pubDate.getMonth() + 1).padStart(2, '0')}.${String(pubDate.getDate()).padStart(2, '0')}`;
const updatedLabel = updatedDate
  ? `${updatedDate.getFullYear()}.${String(updatedDate.getMonth() + 1).padStart(2, '0')}.${String(updatedDate.getDate()).padStart(2, '0')}`
  : '';

// 읽기 시간 추정 (대략 — 한글 600자/분 기준은 본문이 없으니 대략 5분 고정)
const readLabel = '5분';

// 관련 글 — 같은 카테고리 최근 3개 (현재 글 제외)
const related = sortedAll
  .filter((p) => p.id !== id && p.data.tags[0] === cat)
  .slice(0, 3);
---

<BaseLayout title={title} description={description}>
  <div class="qt-post-wrap">
    <section class="qt-post-crumb">
      <span>HOME / {cat ? cat.toUpperCase() : 'NOTE'}{numLabel ? ` / №${numLabel}` : ''}</span>
      <span>{dateLabel}{updatedLabel ? ` / UPD ${updatedLabel}` : ''}</span>
    </section>

    <article class="qt-post">
      <span class="qt-post-mono">// {numLabel || '—'} · {(cat || 'NOTE').toUpperCase()}{sub ? ` / ${sub.toUpperCase()}` : ''}</span>
      <h1 class="qt-post-title">{title}</h1>
      <div class="qt-post-meta">
        {dateLabel} ─ {readLabel}
      </div>
      <p class="qt-post-lede">{description}</p>

      <div class="prose">
        <slot />
      </div>

      <a href={base} class="qt-post-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        목록으로
      </a>

      {related.length > 0 && (
        <section class="qt-post-related">
          <span class="qt-post-related-mono">// RELATED</span>
          {related.map((p) => (
            <PostListRow
              id={p.id}
              title={p.data.title}
              pubDate={p.data.pubDate}
              tags={p.data.tags}
              num={numberMap.get(p.id)}
            />
          ))}
        </section>
      )}
    </article>
  </div>
</BaseLayout>

<style>
  .qt-post-wrap {
    min-height: 100%;
  }

  .qt-post-crumb {
    padding: 10px 36px;
    border-bottom: 1px solid var(--border-hair);
    background: var(--bg-alt);
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--muted);
    letter-spacing: 0.1em;
    display: flex;
    justify-content: space-between;
    max-width: 1200px;
    margin: 0 auto;
    flex-wrap: wrap;
    gap: 8px;
  }

  .qt-post {
    max-width: var(--content-w);
    margin: 0 auto;
    padding: 64px 28px 0;
  }

  .qt-post-mono {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin-bottom: 18px;
  }

  .qt-post-title {
    font-size: calc(42px * var(--h-scale));
    font-weight: 800;
    line-height: 1.18;
    letter-spacing: -0.04em;
    color: var(--ink);
    margin: 0;
  }

  .qt-post-meta {
    margin-top: 20px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border-strong);
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .qt-post-lede {
    font-size: 19px;
    line-height: 1.65;
    color: var(--ink);
    margin: 32px 0;
    font-weight: 600;
    letter-spacing: -0.015em;
  }

  .qt-post-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 56px;
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    border: 1px solid var(--border);
    border-radius: 7px;
    transition: color 0.15s, border-color 0.15s;
  }

  .qt-post-back:hover {
    color: var(--ink);
    border-color: var(--border-strong);
  }

  .qt-post-related {
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  .qt-post-related-mono {
    display: block;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--subtle);
    letter-spacing: 0.12em;
    margin-bottom: 14px;
  }

  @media (max-width: 720px) {
    .qt-post-crumb {
      padding: 10px 20px;
      font-size: 10px;
    }
    .qt-post {
      padding: 40px 20px 0;
    }
    .qt-post-title {
      font-size: calc(28px * var(--h-scale));
    }
    .qt-post-lede {
      font-size: 17px;
    }
  }
</style>
