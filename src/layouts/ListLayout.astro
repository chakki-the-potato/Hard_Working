---
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import PostListRow from '../components/PostListRow.astro';
import TagNav from '../components/TagNav.astro';
import Pagination from '../components/Pagination.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import {
  ALWAYS_VISIBLE_TAGS_PER_CATEGORY,
  categoryLabel,
  type Category,
} from '../lib/categories';

type ListMode =
  | { kind: 'all' }
  | { kind: 'tag'; tag: string }
  | { kind: 'category'; category: Category };

interface Props {
  page: {
    data: Array<{
      id: string;
      data: {
        title: string;
        description: string;
        pubDate: Date;
        category: Category;
        tags: string[];
        heroImage?: string;
      };
    }>;
    currentPage: number;
    lastPage: number;
    url: {
      prev: string | undefined;
      next: string | undefined;
      current: string;
    };
  };
  mode?: ListMode;
}

const { page, mode = { kind: 'all' } } = Astro.props;
const base = import.meta.env.BASE_URL;

const headerLabel =
  mode.kind === 'category' ? `#${categoryLabel(mode.category)}`
  : mode.kind === 'tag' ? `#${mode.tag}`
  : '전체';
const title = mode.kind === 'all' ? SITE_TITLE : `${headerLabel} — ${SITE_TITLE}`;
const heroMono = mode.kind === 'category' ? '// CATEGORY' : '// TAG / FILTER';

// 전체 카운트 + 사이드바 데이터
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const tagCounts = new Map<string, number>();
const categoryCounts = new Map<Category, number>();
const tagsPerCategory = new Map<Category, Map<string, number>>();
for (const p of allPosts) {
  const cat = p.data.category;
  categoryCounts.set(cat, (categoryCounts.get(cat) ?? 0) + 1);
  let perCat = tagsPerCategory.get(cat);
  if (!perCat) {
    perCat = new Map<string, number>();
    tagsPerCategory.set(cat, perCat);
  }
  for (const t of p.data.tags) {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
    perCat.set(t, (perCat.get(t) ?? 0) + 1);
  }
}

const totalCount =
  mode.kind === 'category' ? (categoryCounts.get(mode.category) ?? 0)
  : mode.kind === 'tag' ? (tagCounts.get(mode.tag) ?? 0)
  : allPosts.length;

const sortedAll = [...allPosts].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const lastUpdate = sortedAll[0]?.data.pubDate;
const lastUpdateLabel = lastUpdate
  ? `${lastUpdate.getFullYear()}.${String(lastUpdate.getMonth() + 1).padStart(2, '0')}.${String(lastUpdate.getDate()).padStart(2, '0')}`
  : '';

const baseUrl =
  mode.kind === 'category' ? `${base}posts/category/${mode.category}/`
  : mode.kind === 'tag' ? `${base}tags/${mode.tag}/`
  : base;

// Sidebar: when viewing a category page, list its sub-tags. When viewing a tag page,
// figure out which category that tag mostly belongs to and show siblings.
const activeCategory: Category | undefined =
  mode.kind === 'category'
    ? mode.category
    : mode.kind === 'tag'
      ? (() => {
          let best: Category | undefined;
          let bestCount = 0;
          for (const [c, perCat] of tagsPerCategory.entries()) {
            const count = perCat.get(mode.tag) ?? 0;
            if (count > bestCount) {
              best = c;
              bestCount = count;
            }
          }
          // Fallback: whitelisted tag with no posts yet (e.g. Tools under programming)
          if (!best) {
            for (const [c, tags] of Object.entries(ALWAYS_VISIBLE_TAGS_PER_CATEGORY)) {
              if ((tags ?? []).includes(mode.tag)) {
                best = c as Category;
                break;
              }
            }
          }
          return best;
        })()
      : undefined;

const sidebarTags = activeCategory
  ? [...(tagsPerCategory.get(activeCategory) ?? new Map()).entries()]
      .sort((a, b) => b[1] - a[1])
      .map(([tag, count]) => ({ tag, count }))
  : [];
const activeTagLabel = mode.kind === 'tag' ? mode.tag : undefined;

// 글 번호 매기기 — 발행일 오름차순 1..N (가장 먼저 쓴 글이 №001)
const numberMap = new Map<string, number>();
[...sortedAll].reverse().forEach((p, i) => numberMap.set(p.id, i + 1));
---

<BaseLayout title={title} description={SITE_DESCRIPTION} noPadding={true}>
  <section class="qt-list-hero">
    <span class="qt-mono qt-list-mono">{heroMono}</span>
    <h1 class="qt-list-title">
      {(mode.kind === 'tag' || mode.kind === 'category') && <span class="qt-list-hash">#</span>}
      {mode.kind === 'category' ? categoryLabel(mode.category) : (mode.kind === 'tag' ? mode.tag : '전체')}
    </h1>
    <span class="qt-mono qt-list-meta">
      {totalCount} ARTICLES{lastUpdateLabel ? ` · LAST_UPDATE ${lastUpdateLabel}` : ''}
    </span>
  </section>

  <section class="qt-list-chips">
    <TagNav activeCategory={activeCategory} activeTag={activeTagLabel} />
  </section>

  <div class="qt-list-body">
    <div class="qt-list-main">
      {page.data.length > 0 && (
        <div class="qt-list-thead">
          <span>NO</span>
          <span>TITLE</span>
          <span>CAT/SUB</span>
          <span class="qt-list-thead-right">DATE</span>
        </div>
      )}

      <div class="qt-list-rows">
        {page.data.map((post) => (
          <PostListRow
            id={post.id}
            title={post.data.title}
            pubDate={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags}
            num={numberMap.get(post.id)}
          />
        ))}
      </div>

      {page.data.length === 0 && (
        <div class="qt-list-empty">
          <span class="qt-mono qt-list-empty-mark">// EMPTY</span>
          <p>해당하는 글이 아직 없어요.</p>
        </div>
      )}

      <Pagination
        currentPage={page.currentPage}
        lastPage={page.lastPage}
        baseUrl={baseUrl}
      />
    </div>

    {activeCategory && sidebarTags.length > 0 && (
      <aside class="qt-list-aside">
        <a
          href={`${base}posts/category/${activeCategory}/`}
          class:list={['qt-aside-parent', { 'is-active': mode.kind === 'category' && mode.category === activeCategory }]}
        >
          // {categoryLabel(activeCategory).toUpperCase()}
        </a>
        <div class="qt-aside-list">
          {sidebarTags.map(({ tag, count }) => (
            <a
              href={`${base}tags/${tag}/`}
              class:list={['qt-aside-item', { 'is-active': mode.kind === 'tag' && mode.tag === tag }]}
            >
              <span class="qt-aside-name">{tag}</span>
              <span class="qt-aside-count">{count}</span>
            </a>
          ))}
        </div>
      </aside>
    )}
  </div>
</BaseLayout>

<style>
  .qt-list-hero {
    padding: 64px 36px 28px;
    border-bottom: 1px solid var(--border);
    max-width: 1200px;
    margin: 0 auto;
  }

  .qt-mono {
    font-family: var(--font-mono);
  }

  .qt-list-mono {
    display: block;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.12em;
    margin-bottom: 14px;
  }

  .qt-list-title {
    font-size: calc(64px * var(--h-scale));
    font-weight: 800;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.045em;
    line-height: 1;
  }

  .qt-list-hash {
    color: var(--accent);
  }

  .qt-list-meta {
    display: block;
    font-size: 12px;
    color: var(--muted);
    margin-top: 14px;
    letter-spacing: 0.06em;
  }

  .qt-list-chips {
    padding: 20px 36px;
    border-bottom: 1px solid var(--border);
    max-width: 1200px;
    margin: 0 auto;
  }

  .qt-list-body {
    max-width: 1200px;
    margin: 0 auto;
    padding: 24px 36px 0;
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 56px;
    align-items: start;
  }

  .qt-list-body:not(:has(.qt-list-aside)) {
    grid-template-columns: 1fr;
  }

  .qt-list-main {
    min-width: 0;
  }

  .qt-list-thead {
    display: grid;
    grid-template-columns: 60px 1fr 130px 90px;
    gap: 18px;
    padding: 8px 0;
    border-bottom: 1px solid var(--border-strong);
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.12em;
  }

  .qt-list-thead-right {
    text-align: right;
  }

  .qt-list-empty {
    padding: 60px 0;
    text-align: center;
    color: var(--muted);
  }

  .qt-list-empty-mark {
    display: block;
    font-size: 11px;
    color: var(--subtle);
    letter-spacing: 0.12em;
    margin-bottom: 8px;
  }

  .qt-list-empty p {
    margin: 0;
    font-size: 14px;
  }

  /* 사이드바 */
  .qt-list-aside {
    position: sticky;
    top: 80px;
  }

  .qt-aside-parent {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: 0.12em;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-strong);
  }

  .qt-aside-parent:hover {
    color: var(--accent-ink);
  }

  .qt-aside-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .qt-aside-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 7px 10px;
    border-radius: 6px;
    text-decoration: none;
    transition: background-color 0.12s, color 0.12s;
    color: var(--muted);
  }

  .qt-aside-item:hover {
    background: var(--bg-alt);
    color: var(--ink);
  }

  .qt-aside-item.is-active {
    background: var(--ink);
    color: var(--bg-elev);
  }

  .qt-aside-item.is-active .qt-aside-count {
    color: var(--bg-elev);
    opacity: 0.7;
  }

  .qt-aside-name {
    font-size: 13px;
    font-weight: 500;
  }

  .qt-aside-count {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--subtle);
    letter-spacing: 0.04em;
  }

  /* 반응형 */
  @media (max-width: 900px) {
    .qt-list-body {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .qt-list-aside {
      position: static;
      order: -1;
      margin-bottom: 8px;
    }
    .qt-aside-list {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 6px;
    }
    .qt-aside-item {
      padding: 6px 12px;
      background: var(--bg-alt);
      border: 1px solid var(--border);
    }
  }

  @media (max-width: 720px) {
    .qt-list-hero {
      padding: 40px 20px 20px;
    }
    .qt-list-chips,
    .qt-list-body {
      padding-left: 20px;
      padding-right: 20px;
    }
    .qt-list-title {
      font-size: calc(40px * var(--h-scale));
    }
    .qt-list-thead {
      display: none;
    }
  }
</style>
