---
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import PostListRow from '../components/PostListRow.astro';
import TagNav from '../components/TagNav.astro';
import Pagination from '../components/Pagination.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

interface Props {
  page: {
    data: Array<{
      id: string;
      data: {
        title: string;
        description: string;
        pubDate: Date;
        tags: string[];
        heroImage?: string;
      };
    }>;
    currentPage: number;
    lastPage: number;
    url: {
      prev: string | undefined;
      next: string | undefined;
      current: string;
    };
  };
  activeTag?: string;
}

const { page, activeTag } = Astro.props;
const base = import.meta.env.BASE_URL;
const title = activeTag ? `#${activeTag} — ${SITE_TITLE}` : SITE_TITLE;

// 카테고리 계층
const topCategories = ['Programming', 'Thinking', 'Design'];
const categoryHierarchy: Record<string, string[]> = {
  Programming: ['Frontend', 'Backend', 'DevOps'],
  Thinking: ['Productivity', 'Startup'],
  Design: ['CSS'],
};
const subToParent: Record<string, string> = {};
for (const [parent, subs] of Object.entries(categoryHierarchy)) {
  subs.forEach((sub) => { subToParent[sub] = parent; });
}

const isTopCategory = activeTag ? topCategories.includes(activeTag) : false;
const isSubCategory = activeTag ? !!subToParent[activeTag] : false;
const parentCategory = isSubCategory ? subToParent[activeTag!] : (isTopCategory ? activeTag : undefined);
const sidebarSubs = parentCategory ? (categoryHierarchy[parentCategory] ?? []) : [];

// 전체 카운트
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const tagCounts = new Map<string, number>();
allPosts.forEach((p) => p.data.tags.forEach((t) => tagCounts.set(t, (tagCounts.get(t) || 0) + 1)));
const totalCount = activeTag ? (tagCounts.get(activeTag) ?? 0) : allPosts.length;

const sortedAll = [...allPosts].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const lastUpdate = sortedAll[0]?.data.pubDate;
const lastUpdateLabel = lastUpdate
  ? `${lastUpdate.getFullYear()}.${String(lastUpdate.getMonth() + 1).padStart(2, '0')}.${String(lastUpdate.getDate()).padStart(2, '0')}`
  : '';

const baseUrl = activeTag ? `${base}tags/${activeTag}/` : base;
const headerLabel = activeTag ?? '전체';

// 글 번호 매기기 — 발행일 역순 1..N
const numberMap = new Map<string, number>();
sortedAll.forEach((p, i) => numberMap.set(p.id, i + 1));
---

<BaseLayout title={title} description={SITE_DESCRIPTION} noPadding={true}>
  <section class="qt-list-hero">
    <span class="qt-mono qt-list-mono">// TAG / FILTER</span>
    <h1 class="qt-list-title">
      <span class="qt-list-hash">#</span>{headerLabel}
    </h1>
    <span class="qt-mono qt-list-meta">
      {totalCount} ARTICLES{lastUpdateLabel ? ` · LAST_UPDATE ${lastUpdateLabel}` : ''}
    </span>
  </section>

  <section class="qt-list-chips">
    <TagNav activeTag={activeTag} />
  </section>

  <div class="qt-list-body">
    <div class="qt-list-main">
      {page.data.length > 0 && (
        <div class="qt-list-thead">
          <span>NO</span>
          <span>TITLE</span>
          <span>CAT/SUB</span>
          <span class="qt-list-thead-right">DATE</span>
        </div>
      )}

      <div class="qt-list-rows">
        {page.data.map((post) => (
          <PostListRow
            id={post.id}
            title={post.data.title}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            num={numberMap.get(post.id)}
          />
        ))}
      </div>

      {page.data.length === 0 && (
        <div class="qt-list-empty">
          <span class="qt-mono qt-list-empty-mark">// EMPTY</span>
          <p>이 태그에 해당하는 글이 아직 없어요.</p>
        </div>
      )}

      <Pagination
        currentPage={page.currentPage}
        lastPage={page.lastPage}
        baseUrl={baseUrl}
      />
    </div>

    {parentCategory && sidebarSubs.length > 0 && (
      <aside class="qt-list-aside">
        <a
          href={`${base}tags/${parentCategory}/`}
          class:list={['qt-aside-parent', { 'is-active': activeTag === parentCategory }]}
        >
          // {parentCategory.toUpperCase()}
        </a>
        <div class="qt-aside-list">
          {sidebarSubs.map((sub) => (
            <a
              href={`${base}tags/${sub}/`}
              class:list={['qt-aside-item', { 'is-active': activeTag === sub }]}
            >
              <span class="qt-aside-name">{sub}</span>
              <span class="qt-aside-count">{tagCounts.get(sub) ?? 0}</span>
            </a>
          ))}
        </div>
      </aside>
    )}
  </div>
</BaseLayout>

<style>
  .qt-list-hero {
    padding: 64px 36px 28px;
    border-bottom: 1px solid var(--border);
    max-width: 1200px;
    margin: 0 auto;
  }

  .qt-mono {
    font-family: var(--font-mono);
  }

  .qt-list-mono {
    display: block;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.12em;
    margin-bottom: 14px;
  }

  .qt-list-title {
    font-size: calc(64px * var(--h-scale));
    font-weight: 800;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.045em;
    line-height: 1;
  }

  .qt-list-hash {
    color: var(--accent);
  }

  .qt-list-meta {
    display: block;
    font-size: 12px;
    color: var(--muted);
    margin-top: 14px;
    letter-spacing: 0.06em;
  }

  .qt-list-chips {
    padding: 20px 36px;
    border-bottom: 1px solid var(--border);
    max-width: 1200px;
    margin: 0 auto;
  }

  .qt-list-body {
    max-width: 1200px;
    margin: 0 auto;
    padding: 24px 36px 0;
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 56px;
    align-items: start;
  }

  .qt-list-body:not(:has(.qt-list-aside)) {
    grid-template-columns: 1fr;
  }

  .qt-list-main {
    min-width: 0;
  }

  .qt-list-thead {
    display: grid;
    grid-template-columns: 60px 1fr 130px 90px;
    gap: 18px;
    padding: 8px 0;
    border-bottom: 1px solid var(--border-strong);
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.12em;
  }

  .qt-list-thead-right {
    text-align: right;
  }

  .qt-list-empty {
    padding: 60px 0;
    text-align: center;
    color: var(--muted);
  }

  .qt-list-empty-mark {
    display: block;
    font-size: 11px;
    color: var(--subtle);
    letter-spacing: 0.12em;
    margin-bottom: 8px;
  }

  .qt-list-empty p {
    margin: 0;
    font-size: 14px;
  }

  /* 사이드바 */
  .qt-list-aside {
    position: sticky;
    top: 80px;
  }

  .qt-aside-parent {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: 0.12em;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-strong);
  }

  .qt-aside-parent:hover {
    color: var(--accent-ink);
  }

  .qt-aside-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .qt-aside-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 7px 10px;
    border-radius: 6px;
    text-decoration: none;
    transition: background-color 0.12s, color 0.12s;
    color: var(--muted);
  }

  .qt-aside-item:hover {
    background: var(--bg-alt);
    color: var(--ink);
  }

  .qt-aside-item.is-active {
    background: var(--ink);
    color: var(--bg-elev);
  }

  .qt-aside-item.is-active .qt-aside-count {
    color: var(--bg-elev);
    opacity: 0.7;
  }

  .qt-aside-name {
    font-size: 13px;
    font-weight: 500;
  }

  .qt-aside-count {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--subtle);
    letter-spacing: 0.04em;
  }

  /* 반응형 */
  @media (max-width: 900px) {
    .qt-list-body {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .qt-list-aside {
      position: static;
      order: -1;
      margin-bottom: 8px;
    }
    .qt-aside-list {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 6px;
    }
    .qt-aside-item {
      padding: 6px 12px;
      background: var(--bg-alt);
      border: 1px solid var(--border);
    }
  }

  @media (max-width: 720px) {
    .qt-list-hero {
      padding: 40px 20px 20px;
    }
    .qt-list-chips,
    .qt-list-body {
      padding-left: 20px;
      padding-right: 20px;
    }
    .qt-list-title {
      font-size: calc(40px * var(--h-scale));
    }
    .qt-list-thead {
      display: none;
    }
  }
</style>
