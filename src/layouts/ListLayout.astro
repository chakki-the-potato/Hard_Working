---
import BaseLayout from './BaseLayout.astro';
import TagNav from '../components/TagNav.astro';
import PostCard from '../components/PostCard.astro';
import PostGrid from '../components/PostGrid.astro';
import Pagination from '../components/Pagination.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

interface Props {
  page: {
    data: Array<{
      id: string;
      data: {
        title: string;
        description: string;
        pubDate: Date;
        tags: string[];
        heroImage?: string;
      };
    }>;
    currentPage: number;
    lastPage: number;
    url: {
      prev: string | undefined;
      next: string | undefined;
      current: string;
    };
  };
  activeTag?: string;
}

const { page, activeTag } = Astro.props;
const base = import.meta.env.BASE_URL;
const title = activeTag ? `${activeTag} - ${SITE_TITLE}` : SITE_TITLE;
const baseUrl = activeTag ? `${base}tags/${activeTag}/` : base;
---

<BaseLayout title={title} description={SITE_DESCRIPTION}>
  <TagNav activeTag={activeTag} />
  <PostGrid>
    {page.data.map((post) => (
      <PostCard
        id={post.id}
        title={post.data.title}
        description={post.data.description}
        pubDate={post.data.pubDate}
        tags={post.data.tags}
        heroImage={post.data.heroImage}
      />
    ))}
  </PostGrid>
  {page.data.length === 0 && (
    <p class="text-center py-16" style="color: var(--text-secondary);">
      아직 작성된 글이 없습니다.
    </p>
  )}
  <Pagination
    currentPage={page.currentPage}
    lastPage={page.lastPage}
    baseUrl={baseUrl}
  />
</BaseLayout>
