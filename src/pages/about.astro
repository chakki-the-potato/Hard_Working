---
import BaseLayout from '../layouts/BaseLayout.astro';

const stack = ['TypeScript', 'React', 'Next.js', 'Node.js', 'Python', 'PostgreSQL', 'AWS', 'Astro'];

const timeline: Array<[string, string]> = [
  ['2026', '블로그 v.02 리디자인. 매일 한 편씩 발행 시작.'],
  ['2025', '풀스택 사이드 프로젝트 — 메모 앱, 태스크 트래커.'],
  ['2024', 'Frontend → Full-stack 전환. Next.js + Postgres 본격.'],
  ['2023', '개발 공부 시작. JavaScript와 CSS부터.'],
];

const contact: Array<[string, string, string]> = [
  ['EMAIL', 'chanhee2468@gmail.com', 'mailto:chanhee2468@gmail.com'],
  ['GITHUB', 'github.com/chakki-the-potato', 'https://github.com/chakki-the-potato'],
  ['RSS', 'rss.xml', `${import.meta.env.BASE_URL}rss.xml`],
];
---

<BaseLayout title="About — Hard_Working" description="블로그 운영자 소개" noPadding={true}>
  <section class="qt-about-hero">
    <span class="qt-mono qt-about-mono">// ABOUT</span>
    <h1 class="qt-about-title">
      공부 노트<br />
      쓰는 사람<span class="qt-about-dot">.</span>
    </h1>
    <p class="qt-about-desc">
      웹 개발과 사고의 결을 매일 한 편씩 정리합니다. 빠른 답보다 천천히 이해하는 쪽을 좋아해요.
    </p>
  </section>

  <main class="qt-about-main">
    <div class="qt-about-row">
      <span class="qt-mono qt-about-key">// STACK</span>
      <div class="qt-about-stack">
        {stack.map((s) => (
          <span class="qt-stack-chip">{s}</span>
        ))}
      </div>
    </div>

    <div class="qt-about-row">
      <span class="qt-mono qt-about-key">// TIMELINE</span>
      <div class="qt-about-timeline">
        {timeline.map(([y, t]) => (
          <div class="qt-timeline-item">
            <span class="qt-timeline-year">{y}</span>
            <span class="qt-timeline-text">{t}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="qt-about-row qt-about-row-last">
      <span class="qt-mono qt-about-key">// CONTACT</span>
      <div class="qt-about-contact">
        {contact.map(([k, v, href]) => (
          <div class="qt-contact-item">
            <span class="qt-contact-key">{k}</span>
            <a href={href} class="qt-contact-value" target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noopener' : undefined}>{v}</a>
          </div>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .qt-mono {
    font-family: var(--font-mono);
  }

  .qt-about-hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 88px 36px 56px;
    border-bottom: 1px solid var(--border);
  }

  .qt-about-mono {
    display: block;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.12em;
    margin-bottom: 16px;
  }

  .qt-about-title {
    font-size: calc(64px * var(--h-scale));
    font-weight: 800;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.045em;
    line-height: 1.05;
  }

  .qt-about-dot {
    color: var(--accent);
  }

  .qt-about-desc {
    font-size: 17px;
    color: var(--muted);
    margin-top: 24px;
    max-width: 540px;
    line-height: 1.65;
    font-weight: 500;
  }

  .qt-about-main {
    max-width: 720px;
    margin: 0 auto;
    padding: 56px 28px 0;
  }

  .qt-about-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 36px;
    padding: 32px 0;
    border-bottom: 1px solid var(--border-hair);
  }

  .qt-about-row-last {
    border-bottom: none;
  }

  .qt-about-row:first-child {
    padding-top: 0;
  }

  .qt-about-key {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.06em;
  }

  /* STACK */
  .qt-about-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .qt-stack-chip {
    padding: 4px 10px;
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--muted);
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: 4px;
    letter-spacing: 0.04em;
  }

  /* TIMELINE */
  .qt-about-timeline {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .qt-timeline-item {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 16px;
    padding: 8px 0;
  }

  .qt-timeline-year {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .qt-timeline-text {
    font-size: 14px;
    color: var(--body);
    line-height: 1.6;
  }

  /* CONTACT */
  .qt-about-contact {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .qt-contact-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 12px;
    align-items: baseline;
  }

  .qt-contact-key {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--subtle);
    letter-spacing: 0.1em;
  }

  .qt-contact-value {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
    width: fit-content;
    transition: opacity 0.15s;
  }

  .qt-contact-value:hover {
    opacity: 0.7;
  }

  @media (max-width: 720px) {
    .qt-about-hero {
      padding: 56px 20px 40px;
    }
    .qt-about-title {
      font-size: calc(40px * var(--h-scale));
    }
    .qt-about-main {
      padding: 32px 20px 0;
    }
    .qt-about-row {
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 24px 0;
    }
  }
</style>
