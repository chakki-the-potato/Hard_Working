---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CATEGORIES, categoryLabel, type Category } from '../lib/categories';
import { loadHomeData } from '../lib/home-data';

const base = import.meta.env.BASE_URL;
const home = await loadHomeData();

const categoryDescriptions: Record<Category, string> = {
  programming: '웹 개발·도구·트러블슈팅 노트',
  design: 'UI/UX·디자인 시스템·시각 언어',
  thinking: '사고·커리어·메타 학습',
  works: '사이드 프로젝트·실험',
};

const categoryGuide = CATEGORIES.map((slug) => ({
  slug,
  label: categoryLabel(slug),
  description: categoryDescriptions[slug],
  count: home.categoryCounts[slug],
  href: `${base}posts/category/${slug}/`,
}));

const now: Array<[string, string]> = [
  ['LEARNING', 'Astro content collections 깊이 파기'],
  ['READING', '《함께 자라기》 — 김창준'],
  ['BUILDING', 'Hard_Working 블로그 v.02'],
];
const nowUpdated = '2026-04-30';

const stack = ['TypeScript', 'React', 'Next.js', 'Node.js', 'Python', 'PostgreSQL', 'AWS', 'Astro'];

const timeline: Array<[string, string]> = [
  ['2026', '블로그 v.02 리디자인. 매일 한 편씩 발행 시작.'],
  ['2025', '풀스택 사이드 프로젝트 — 메모 앱, 태스크 트래커.'],
  ['2024', 'Frontend → Full-stack 전환. Next.js + Postgres 본격.'],
  ['2023', '개발 공부 시작. JavaScript와 CSS부터.'],
];

const contact: Array<[string, string, string]> = [
  ['EMAIL', 'chanhee2468@gmail.com', 'mailto:chanhee2468@gmail.com'],
  ['GITHUB', 'github.com/chakki-the-potato', 'https://github.com/chakki-the-potato'],
  ['RSS', 'rss.xml', `${base}rss.xml`],
];
---

<BaseLayout title="About — Hard_Working" description="블로그 운영자 소개" noPadding={true}>
  <section class="qt-about-hero">
    <span class="qt-mono qt-about-mono">// ABOUT</span>
    <h1 class="qt-about-title">
      공부 노트<br />
      쓰는 사람<span class="qt-about-dot">.</span>
    </h1>
    <p class="qt-about-desc">
      웹 개발과 사고의 결을 매일 한 편씩 정리합니다. 빠른 답보다 천천히 이해하는 쪽을 좋아해요.
    </p>
  </section>

  <main class="qt-about-main">
    <div class="qt-about-row">
      <span class="qt-mono qt-about-key">// CATEGORIES</span>
      <ul class="qt-about-categories">
        {categoryGuide.map((c) => (
          <li class="qt-category-item">
            <a class="qt-category-link" href={c.href}>
              <span class="qt-category-name">{c.label}</span>
              <span class="qt-category-count">· {c.count}</span>
              <span class="qt-category-desc">{c.description}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="qt-about-row">
      <span class="qt-mono qt-about-key">
        // NOW
        <span class="qt-now-updated">updated {nowUpdated}</span>
      </span>
      <ul class="qt-about-now">
        {now.map(([k, v]) => (
          <li class="qt-now-item">
            <span class="qt-now-key">{k}</span>
            <span class="qt-now-text">{v}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="qt-about-row">
      <span class="qt-mono qt-about-key">// STACK</span>
      <div class="qt-about-stack">
        {stack.map((s) => (
          <span class="qt-stack-chip">{s}</span>
        ))}
      </div>
    </div>

    <div class="qt-about-row">
      <span class="qt-mono qt-about-key">// TIMELINE</span>
      <div class="qt-about-timeline">
        {timeline.map(([y, t]) => (
          <div class="qt-timeline-item">
            <span class="qt-timeline-year">{y}</span>
            <span class="qt-timeline-text">{t}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="qt-about-row qt-about-row-last">
      <span class="qt-mono qt-about-key">// CONTACT</span>
      <div class="qt-about-contact">
        {contact.map(([k, v, href]) => (
          <div class="qt-contact-item">
            <span class="qt-contact-key">{k}</span>
            <a href={href} class="qt-contact-value" target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noopener' : undefined}>{v}</a>
          </div>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .qt-mono {
    font-family: var(--font-mono);
  }

  .qt-about-hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 88px 36px 56px;
    border-bottom: 1px solid var(--border);
  }

  .qt-about-mono {
    display: block;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.12em;
    margin-bottom: 16px;
  }

  .qt-about-title {
    font-size: calc(64px * var(--h-scale));
    font-weight: 800;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.045em;
    line-height: 1.05;
  }

  .qt-about-dot {
    color: var(--accent);
  }

  .qt-about-desc {
    font-size: 17px;
    color: var(--muted);
    margin-top: 24px;
    max-width: 540px;
    line-height: 1.65;
    font-weight: 500;
  }

  .qt-about-main {
    max-width: 720px;
    margin: 0 auto;
    padding: 56px 28px 0;
  }

  .qt-about-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 36px;
    padding: 32px 0;
    border-bottom: 1px solid var(--border-hair);
  }

  .qt-about-row-last {
    border-bottom: none;
  }

  .qt-about-row:first-child {
    padding-top: 0;
  }

  .qt-about-key {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.06em;
  }

  /* CATEGORIES */
  .qt-about-categories {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .qt-category-item {
    margin: 0;
  }

  .qt-category-link {
    display: grid;
    grid-template-columns: 132px 40px 1fr;
    gap: 12px;
    align-items: baseline;
    padding: 8px 0;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.15s;
  }

  .qt-category-link:hover {
    opacity: 0.7;
  }

  .qt-category-name {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .qt-category-count {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    font-weight: 600;
  }

  .qt-category-desc {
    font-size: 14px;
    color: var(--body);
    line-height: 1.5;
  }

  /* NOW */
  .qt-now-updated {
    margin-left: 8px;
    color: var(--subtle);
    font-size: 10.5px;
    letter-spacing: 0.04em;
    text-transform: none;
  }

  .qt-about-now {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .qt-now-item {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: 16px;
    align-items: baseline;
    padding: 8px 0;
  }

  .qt-now-key {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.08em;
  }

  .qt-now-text {
    font-size: 14px;
    color: var(--body);
    line-height: 1.6;
  }

  /* STACK */
  .qt-about-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .qt-stack-chip {
    padding: 4px 10px;
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--muted);
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: 4px;
    letter-spacing: 0.04em;
  }

  /* TIMELINE */
  .qt-about-timeline {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .qt-timeline-item {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 16px;
    padding: 8px 0;
  }

  .qt-timeline-year {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .qt-timeline-text {
    font-size: 14px;
    color: var(--body);
    line-height: 1.6;
  }

  /* CONTACT */
  .qt-about-contact {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .qt-contact-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 12px;
    align-items: baseline;
  }

  .qt-contact-key {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--subtle);
    letter-spacing: 0.1em;
  }

  .qt-contact-value {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
    width: fit-content;
    transition: opacity 0.15s;
  }

  .qt-contact-value:hover {
    opacity: 0.7;
  }

  @media (max-width: 720px) {
    .qt-about-hero {
      padding: 56px 20px 40px;
    }
    .qt-about-title {
      font-size: calc(40px * var(--h-scale));
    }
    .qt-about-main {
      padding: 32px 20px 0;
    }
    .qt-about-row {
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 24px 0;
    }
    .qt-category-link {
      grid-template-columns: 110px 32px 1fr;
      gap: 8px;
    }
    .qt-now-item {
      grid-template-columns: 80px 1fr;
      gap: 12px;
    }
  }
</style>
