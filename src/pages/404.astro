---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostListRow from '../components/PostListRow.astro';

const base = import.meta.env.BASE_URL;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedAll = [...allPosts].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const numberMap = new Map<string, number>();
[...sortedAll].reverse().forEach((p, i) => numberMap.set(p.id, i + 1));
const suggestions = sortedAll.slice(0, 3);
---

<BaseLayout title="404 — Hard_Working" description="페이지를 찾을 수 없습니다" noPadding={true}>
  <main class="qt-404">
    <span class="qt-404-mono">// ERROR_404 ─ STATUS: NOT_FOUND</span>
    <h1 class="qt-404-num">
      4<span class="qt-404-zero">0</span>4
    </h1>
    <p class="qt-404-title">이 페이지는 아직 쓰이지 않았습니다.</p>
    <p class="qt-404-desc">
      URL이 바뀌었거나, 글이 삭제되었을 수 있어요. 홈으로 돌아가거나 검색을 시도해 주세요.
    </p>
    <div class="qt-404-actions">
      <a href={base} class="qt-404-btn-primary">홈으로</a>
      <button type="button" class="qt-404-btn-ghost" data-cmdk-trigger>
        검색
        <span class="qt-404-key">⌘K</span>
      </button>
    </div>

    {suggestions.length > 0 && (
      <section class="qt-404-related">
        <span class="qt-404-related-mono">// MAYBE YOU MEANT</span>
        {suggestions.map((p) => (
          <PostListRow
            id={p.id}
            title={p.data.title}
            pubDate={p.data.pubDate}
            tags={p.data.tags}
            num={numberMap.get(p.id)}
          />
        ))}
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .qt-404 {
    max-width: 1200px;
    margin: 0 auto;
    padding: 96px 36px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .qt-404-mono {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.12em;
    margin-bottom: 8px;
  }

  .qt-404-num {
    font-family: var(--font-mono);
    font-size: calc(140px * var(--h-scale));
    font-weight: 800;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.06em;
    line-height: 1;
  }

  .qt-404-zero {
    color: var(--accent);
  }

  .qt-404-title {
    font-size: 18px;
    color: var(--ink);
    margin: 18px 0 4px;
    font-weight: 600;
    letter-spacing: -0.015em;
  }

  .qt-404-desc {
    font-size: 14px;
    color: var(--muted);
    margin: 0 0 28px;
    max-width: 420px;
    line-height: 1.65;
  }

  .qt-404-actions {
    display: flex;
    gap: 8px;
  }

  .qt-404-btn-primary {
    padding: 10px 18px;
    font-size: 13px;
    font-weight: 600;
    color: var(--bg-elev);
    background: var(--ink);
    border-radius: 7px;
    text-decoration: none;
    letter-spacing: -0.01em;
    border: none;
  }

  .qt-404-btn-primary:hover {
    opacity: 0.85;
  }

  .qt-404-btn-ghost {
    padding: 10px 16px;
    font-size: 13px;
    font-weight: 600;
    color: var(--ink);
    background: transparent;
    border: 1px solid var(--border-strong);
    border-radius: 7px;
    cursor: pointer;
    font-family: inherit;
    letter-spacing: -0.01em;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .qt-404-key {
    font-family: var(--font-mono);
    font-size: 10.5px;
    padding: 1px 5px;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--muted);
  }

  .qt-404-related {
    margin-top: 56px;
    width: 100%;
    max-width: 560px;
    text-align: left;
  }

  .qt-404-related-mono {
    display: block;
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--subtle);
    letter-spacing: 0.12em;
    margin-bottom: 12px;
  }

  @media (max-width: 720px) {
    .qt-404 {
      padding: 64px 20px;
    }
    .qt-404-num {
      font-size: calc(96px * var(--h-scale));
    }
  }
</style>
