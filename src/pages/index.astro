---
import { getCollection } from 'astro:content';
import HomeLayout from '../layouts/HomeLayout.astro';
import { POSTS_PER_PAGE, FEATURED_COUNT } from '../consts';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const tagSet = new Set<string>();
sortedPosts.forEach((p) => p.data.tags.forEach((t) => tagSet.add(t)));

const featured = sortedPosts.slice(0, FEATURED_COUNT);
const archive = sortedPosts.slice(FEATURED_COUNT);

const lastPage = Math.max(1, Math.ceil(archive.length / POSTS_PER_PAGE));
const base = import.meta.env.BASE_URL;

const archivePage = {
  data: archive.slice(0, POSTS_PER_PAGE),
  currentPage: 1,
  lastPage,
  url: {
    prev: undefined,
    next: lastPage > 1 ? `${base}page/2/` : undefined,
    current: base,
  },
};
---

<HomeLayout
  featured={featured}
  archivePage={archivePage}
  totalArticles={sortedPosts.length}
  totalTags={tagSet.size}
  lastUpdate={sortedPosts[0]?.data.pubDate}
/>
