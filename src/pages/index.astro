---
import { getCollection } from 'astro:content';
import HomeLayout from '../layouts/HomeLayout.astro';
import { POSTS_PER_PAGE, FEATURED_COUNT } from '../consts';
import { loadHomeData } from '../lib/home-data';

const home = await loadHomeData();

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featured = sortedPosts.slice(0, FEATURED_COUNT);
const archive = sortedPosts.slice(FEATURED_COUNT);

const lastPage = Math.max(1, Math.ceil(archive.length / POSTS_PER_PAGE));
const base = import.meta.env.BASE_URL;

const archivePage = {
  data: archive.slice(0, POSTS_PER_PAGE),
  currentPage: 1,
  lastPage,
  url: {
    prev: undefined,
    next: lastPage > 1 ? `${base}page/2/` : undefined,
    current: base,
  },
};
---

<HomeLayout
  featured={featured}
  archivePage={archivePage}
  totalArticles={home.totalArticles}
  totalTags={home.totalTags}
  lastUpdate={home.lastUpdate}
  categoryCounts={home.categoryCounts}
  topTags={home.topTags}
  recentActivity={home.recentActivity}
  recentIdeas={home.recentIdeas}
/>
