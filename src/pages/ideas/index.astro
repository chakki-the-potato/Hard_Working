---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import IdeaCard from '../../components/IdeaCard.astro';

const ideas = await getCollection('ideas', ({ data }) => !data.draft);
const sortedIdeas = ideas.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Ideas — Hard_Working" description="러프하게 떠오른 아이디어들" noPadding={true}>
  <section class="qt-ideas-hero">
    <span class="qt-mono qt-ideas-mono">// IDEAS / SCRATCHPAD</span>
    <h1 class="qt-ideas-title">
      아이디어<span class="qt-ideas-dot">.</span>
    </h1>
    <p class="qt-ideas-desc">
      정리되지 않은 메모와 발전시킬 만한 방향들. 글이 되기 전 단계의 러프한 노트.
    </p>
    <span class="qt-mono qt-ideas-meta">{sortedIdeas.length} NOTES</span>
  </section>

  <main class="qt-ideas-main">
    {sortedIdeas.length === 0 ? (
      <div class="qt-ideas-empty">
        <span class="qt-mono qt-ideas-empty-mark">// EMPTY</span>
        <p>아직 아이디어가 없습니다.</p>
      </div>
    ) : (
      <div class="qt-ideas-list">
        {sortedIdeas.map((entry) => (
          <IdeaCard entry={entry} />
        ))}
      </div>
    )}
  </main>
</BaseLayout>

<style>
  .qt-mono {
    font-family: var(--font-mono);
  }

  .qt-ideas-hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 64px 36px 28px;
    border-bottom: 1px solid var(--border);
  }

  .qt-ideas-mono {
    display: block;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.12em;
    margin-bottom: 14px;
  }

  .qt-ideas-title {
    font-size: calc(64px * var(--h-scale));
    font-weight: 800;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.045em;
    line-height: 1;
  }

  .qt-ideas-dot {
    color: var(--accent);
  }

  .qt-ideas-desc {
    font-size: 17px;
    color: var(--muted);
    margin: 18px 0 0;
    max-width: 540px;
    line-height: 1.65;
    font-weight: 500;
  }

  .qt-ideas-meta {
    display: block;
    font-size: 12px;
    color: var(--muted);
    margin-top: 14px;
    letter-spacing: 0.06em;
  }

  .qt-ideas-main {
    max-width: 740px;
    margin: 0 auto;
    padding: 32px 28px 0;
  }

  .qt-ideas-empty {
    padding: 60px 0;
    text-align: center;
    color: var(--muted);
  }

  .qt-ideas-empty-mark {
    display: block;
    font-size: 11px;
    color: var(--subtle);
    letter-spacing: 0.12em;
    margin-bottom: 8px;
  }

  .qt-ideas-empty p {
    margin: 0;
    font-size: 14px;
  }

  @media (max-width: 720px) {
    .qt-ideas-hero {
      padding: 40px 20px 20px;
    }
    .qt-ideas-title {
      font-size: calc(40px * var(--h-scale));
    }
    .qt-ideas-main {
      padding: 24px 20px 0;
    }
  }
</style>
